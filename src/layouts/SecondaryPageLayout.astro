---
import BaseLayout from './BaseLayout.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import SidePanel from '../components/SidePanel.astro';

interface Props {
  title: string;
  description: string;
  keywords?: string;
  canonical: string;
  ogTitle?: string;
  ogDescription?: string;
  ogImage?: string;
  ogType?: string;
}

const {
  title,
  description,
  keywords,
  canonical,
  ogTitle = title,
  ogDescription = description,
  ogImage,
  ogType = 'website',
} = Astro.props;
---

<BaseLayout
  title={title}
  description={description}
  keywords={keywords}
  canonical={canonical}
  ogTitle={ogTitle}
  ogDescription={ogDescription}
  ogImage={ogImage}
  ogType={ogType}
>
  <Fragment slot="head">
    <slot name="head" />
  </Fragment>

  <a
    href="#main-content"
    class="sr-only focus:not-sr-only focus:absolute focus:top-4 focus:left-4 focus:z-50 focus:bg-white focus:text-black focus:px-4 focus:py-2 focus:rounded"
  >
    Skip to main content
  </a>

  <div class="container mx-auto p-4 sm:p-8">
    <Header />
    <slot />
    <Footer />
  </div>

  <SidePanel />

  <script src="/js/side-panel.js" is:inline></script>
  <script src="/js/dropdowns.js" is:inline></script>
  <slot name="scripts" />
</BaseLayout>
