---
import SecondaryPageLayout from './SecondaryPageLayout.astro';
import BlogHeader from '../components/BlogHeader.astro';
import BlogSidebar from '../components/BlogSidebar.astro';
import ShareButtons from '../components/ShareButtons.astro';
import ScrollToTop from '../components/ScrollToTop.astro';
import Author from '../blocks/Author/Author.astro';
import authorInfo from '../data/authorInfo.js';
import { getBlogPromo } from '../data/blogPromos';
import { getBlogNeighborsForPathname } from '../utils/blogNeighbors';
import { toSchemaDateTimeUtc } from '../utils/schemaDateTime';

interface Props {
  title: string;
  description: string;
  category: string;
  publishedDate: string;
  dateIso: string;
  /** When the article body was revised after first publish (JSON-LD `dateModified`). */
  dateModifiedIso?: string;
  ogImage?: string;
  youtubeId?: string;
  tags?: string[];
}

const {
  title,
  description,
  category,
  publishedDate,
  dateIso,
  dateModifiedIso,
  ogImage,
  youtubeId,
  tags
} = Astro.props;

const canonical = `https://www.teamrespawn.net${Astro.url.pathname}`;
const resolvedOgImage =
  ogImage && /^https?:\/\//i.test(ogImage)
    ? ogImage
    : ogImage
      ? `https://www.teamrespawn.net${ogImage}`
      : undefined;
const blogPromo = getBlogPromo(category, tags ?? []);
const { prev, next, readingMinutes } = getBlogNeighborsForPathname(Astro.url.pathname);
const datePublishedLd = toSchemaDateTimeUtc(dateIso);
const dateModifiedLd = toSchemaDateTimeUtc(dateModifiedIso ?? dateIso);

// JSON-LD structured data for Article
const jsonLd = {
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": title,
  "description": description,
  "image": resolvedOgImage,
  "datePublished": datePublishedLd,
  "dateModified": dateModifiedLd,
  "author": {
    "@type": "Organization",
    "name": "Team Respawn",
    "url": "https://www.teamrespawn.net"
  },
  "publisher": {
    "@type": "Organization",
    "name": "Team Respawn",
    "logo": {
      "@type": "ImageObject",
      "url": "https://www.teamrespawn.net/content/Team-Respawn-Full.png"
    }
  },
  "mainEntityOfPage": {
    "@type": "WebPage",
    "@id": canonical
  }
};

// Add video object if YouTube ID is provided
if (youtubeId) {
  jsonLd["video"] = {
    "@type": "VideoObject",
    "name": title,
    "description": description,
    "thumbnailUrl": `https://img.youtube.com/vi/${youtubeId}/maxresdefault.jpg`,
    "uploadDate": datePublishedLd,
    "embedUrl": `https://www.youtube.com/embed/${youtubeId}`
  };
}
---
<SecondaryPageLayout
  title={`${title} | Team Respawn Blog`}
  description={description}
  canonical={canonical}
  ogTitle={title}
  ogDescription={description}
  ogImage={resolvedOgImage}
  ogType="article"
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
  </Fragment>

  <BlogHeader />

  <div class="w-full flex flex-col lg:flex-row gap-8">
    <!-- Sidebar (appears first on mobile, moves to right on desktop) -->
    <div class="lg:order-2 lg:w-64 lg:flex-shrink-0">
      <BlogSidebar category={category} title={title} showScrollToTop>
        <ShareButtons url={canonical} title={title} />
      </BlogSidebar>
    </div>

    <!-- Main Content -->
    <main id="main-content" class="flex-1 min-w-0">
      <h1 class="text-4xl font-bold mb-2 text-cyan-400">{title}</h1>
      <p class="text-gray-400 text-sm mb-8 flex flex-wrap items-center gap-x-2 gap-y-1">
        <span><time datetime={dateIso}>{publishedDate}</time> by Team Respawn</span>
        {readingMinutes != null ? (
          <span class="text-gray-500" aria-label={`Estimated reading time ${readingMinutes} minutes`}>
            · ~{readingMinutes} min read
          </span>
        ) : null}
        {dateModifiedIso && dateModifiedIso !== dateIso ? (
          <span class="text-gray-500">
            · Updated <time datetime={dateModifiedIso}>{new Date(dateModifiedIso + 'T00:00:00').toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}</time>
          </span>
        ) : null}
      </p>

      {tags?.length ? (
        <div class="flex flex-wrap gap-2 mb-6">
          {tags.map(tag => (
            <a
              href={`/blog?tag=${encodeURIComponent(tag.toLowerCase())}`}
              class="text-xs font-semibold uppercase tracking-wide bg-gray-800 text-cyan-200 border border-cyan-500/30 rounded-full px-3 py-1 inline-block transition-all duration-200 hover:bg-cyan-800 hover:border-cyan-400 hover:text-white focus:outline-none focus:ring-2 focus:ring-cyan-400 focus:ring-offset-2 focus:ring-offset-gray-900"
            >
              {tag}
            </a>
          ))}
        </div>
      ) : null}

      {youtubeId && (
        <div class="aspect-video mb-8 rounded-lg overflow-hidden shadow-lg">
          <iframe
            src={`https://www.youtube.com/embed/${youtubeId}`}
            title={title}
            loading="lazy"
            allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
            allowfullscreen
            class="h-full w-full border-0"
          ></iframe>
        </div>
      )}

      <div id="blog-toc-mount" class="blog-toc-mount mb-6" aria-live="polite"></div>

      <div class="prose prose-invert text-gray-300">
        <slot />
      </div>

      {(prev || next) && (
        <nav
          class="not-prose mt-10 flex flex-col gap-3 rounded-lg border border-gray-700/80 bg-gray-900/40 p-4 sm:flex-row sm:justify-between"
          aria-label="Adjacent posts"
        >
          {prev ? (
            <a
              href={prev.href}
              class="text-cyan-400 hover:text-cyan-300 focus:outline-none focus:ring-2 focus:ring-cyan-400 rounded sm:max-w-[48%]"
            >
              <span class="block text-xs uppercase tracking-wide text-gray-500">Older</span>
              <span class="font-medium text-gray-100">{prev.title}</span>
            </a>
          ) : (
            <span />
          )}
          {next ? (
            <a
              href={next.href}
              class="text-right text-cyan-400 hover:text-cyan-300 focus:outline-none focus:ring-2 focus:ring-cyan-400 rounded sm:max-w-[48%] sm:ml-auto"
            >
              <span class="block text-xs uppercase tracking-wide text-gray-500">Newer</span>
              <span class="font-medium text-gray-100">{next.title}</span>
            </a>
          ) : null}
        </nav>
      )}

      <!-- Author Block -->
      <div class="mt-12 pb-8 border-b border-gray-700">
        <h2 class="text-lg font-semibold text-gray-400 mb-4">About the Author</h2>
        <Author {...authorInfo} className="bg-gray-800/50 border border-gray-700" />
      </div>

      {blogPromo && (
        <section class={`mt-8 bg-gradient-to-r rounded-xl p-6 border ${blogPromo.sectionClass}`}>
          <div class="flex flex-col sm:flex-row sm:items-center justify-between gap-4 mb-4">
            <div class="flex items-center gap-3">
              <i class={`fab fa-discord ${blogPromo.accentClass} text-3xl`} aria-hidden="true"></i>
              <h2 class={`text-2xl sm:text-3xl font-bold text-transparent bg-clip-text bg-gradient-to-r ${blogPromo.titleClass}`}>
                {blogPromo.title}
              </h2>
            </div>
            <div class="flex flex-col sm:flex-row gap-2">
              <a
                href="/storehaus"
                class={`inline-flex items-center justify-center px-4 py-2 rounded-lg text-white font-semibold transition-colors duration-300 ${blogPromo.learnMoreClass}`}
              >
                <i class="fas fa-info-circle mr-2" aria-hidden="true"></i>
                Learn More
              </a>
              <a
                href="/storehaus-invite"
                target="_blank"
                rel="noopener noreferrer"
                class="inline-flex items-center justify-center bg-purple-600 hover:bg-purple-700 px-4 py-2 rounded-lg text-white font-semibold transition-colors duration-300"
              >
                <i class="fab fa-discord mr-2" aria-hidden="true"></i>
                Add to Discord
              </a>
            </div>
          </div>
          <p class="text-gray-300 mb-6 text-base sm:text-lg">
            {blogPromo.description}
          </p>
          <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
            {blogPromo.features.map((feature) => (
              <div class={`bg-gray-800/60 p-4 rounded-lg border border-gray-700/60 transition-colors duration-300 ${blogPromo.featureCardClass}`}>
                <i class={`${feature.icon} ${blogPromo.accentClass} text-2xl mb-2`} aria-hidden="true"></i>
                <h3 class={`font-semibold mb-1 ${blogPromo.featureTitleClass}`}>{feature.title}</h3>
                <p class="text-sm text-gray-400">{feature.description}</p>
              </div>
            ))}
          </div>
        </section>
      )}
    </main>
  </div>

  <div class="w-full mt-8 lg:hidden">
    <ScrollToTop variant="sidebar" />
  </div>

  <Fragment slot="scripts">
    <script src="/js/blog-toc.js" is:inline></script>
  </Fragment>
</SecondaryPageLayout>

<style is:global>
  .blog-toc-mount:empty {
    display: none;
  }

  .blog-toc {
    position: relative;
    border-radius: 0.75rem;
    border: 1px solid rgba(148, 163, 184, 0.22);
    background: linear-gradient(135deg, rgba(17, 24, 39, 0.97) 0%, rgba(15, 23, 42, 0.92) 45%, rgba(8, 15, 30, 0.94) 100%);
    box-shadow:
      0 1px 0 rgba(255, 255, 255, 0.04) inset,
      0 12px 32px rgba(2, 6, 23, 0.55);
    overflow: hidden;
  }

  .blog-toc::before {
    content: '';
    position: absolute;
    left: 0;
    top: 0;
    bottom: 0;
    width: 4px;
    background: linear-gradient(180deg, #22d3ee 0%, #0891b2 55%, #164e63 100%);
    opacity: 0.95;
    pointer-events: none;
  }

  .blog-toc__inner {
    padding: 1rem 1.25rem 1.125rem 1.5rem;
  }

  .blog-toc__label {
    margin: 0 0 0.75rem;
    font-size: 0.6875rem;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: rgba(103, 232, 249, 0.9);
  }

  .blog-toc__list {
    margin: 0;
    padding: 0;
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0.125rem;
  }

  .blog-toc__item {
    margin: 0;
    padding: 0;
    position: relative;
    padding-left: 0.875rem;
  }

  .blog-toc__item::before {
    content: '';
    position: absolute;
    left: 0;
    top: 0.65em;
    width: 6px;
    height: 6px;
    border-radius: 9999px;
    background: rgba(34, 211, 238, 0.35);
    box-shadow: 0 0 0 2px rgba(34, 211, 238, 0.12);
  }

  .blog-toc__link {
    display: block;
    padding: 0.4rem 0.5rem;
    margin-left: -0.25rem;
    border-radius: 0.375rem;
    font-size: 0.875rem;
    line-height: 1.45;
    font-weight: 500;
    color: #cbd5e1;
    text-decoration: none;
    border: 1px solid transparent;
    transition:
      color 0.15s ease,
      background 0.15s ease,
      border-color 0.15s ease;
  }

  .blog-toc__link:hover {
    color: #ecfeff;
    background: rgba(6, 182, 212, 0.1);
    border-color: rgba(34, 211, 238, 0.15);
  }

  .blog-toc__link:focus {
    outline: none;
  }

  .blog-toc__link:focus-visible {
    outline: 2px solid #22d3ee;
    outline-offset: 2px;
    color: #ecfeff;
  }

  @media (min-width: 1024px) {
    .blog-toc__inner {
      padding: 1.125rem 1.375rem 1.25rem 1.625rem;
    }

    .blog-toc__link {
      font-size: 0.9375rem;
    }
  }
</style>
