---
import SocialIcons from './SocialIcons.astro';
import {
  isNavLinkActive,
  normalizePathname,
  sidePanelPrimaryLinks,
} from '../data/navigation';

const pathname = Astro.url?.pathname ?? '';
const normalizedPath = normalizePathname(pathname);
const isHome = pathname === '/' || pathname === '/index.html';
const isHw2Stats = normalizedPath === '/halo-wars-stats';
const isHw2GuideHub = normalizedPath === '/halo-wars-guides';
const isVideos = pathname.startsWith('/videos');
const navFlags = { isVideos, isHw2Stats };

const primaryLinks = sidePanelPrimaryLinks.map((link) => ({
  ...link,
  active: isNavLinkActive(link, pathname, navFlags),
}));

const primaryLinkClass = (active: boolean) =>
  `side-panel-tab-link ${active ? 'side-panel-tab-active' : 'side-panel-tab-inactive'} flex items-center gap-3 text-left text-base font-semibold transition-all duration-200 py-3 px-3 rounded-xl hover:bg-gray-800/50`;

const featureCardClass = (active: boolean) =>
  `block rounded-2xl border p-4 transition-all duration-200 ${
    active
      ? 'border-cyan-400/30 bg-cyan-950/30 shadow-[inset_0_0_0_1px_rgba(34,211,238,0.08)]'
      : 'border-white/10 bg-white/5 hover:border-white/20 hover:bg-white/[0.07]'
  }`;

const featuredLinks = [
  {
    href: '/halo-wars-guides',
    title: 'Halo Wars 2 Guide Hub',
    description: 'Beginner routes, matchup help, and leader picks.',
    eyebrow: 'Featured',
    icon: 'fas fa-book-open',
    active: isHw2GuideHub,
  },
  {
    href: '/halo-wars-stats',
    title: 'HW2 Stats',
    description: 'Search players, CSR, leaders, and recent match history.',
    eyebrow: 'Tool',
    icon: 'fas fa-chart-bar',
    active: isHw2Stats,
  },
  {
    href: '/partner',
    title: 'Partner With Us',
    description: 'Sponsorships, collaborations, and brand partnerships.',
    eyebrow: 'About',
    icon: 'fas fa-handshake',
    active: normalizedPath === '/partner',
  },
];
---
<aside
  id="side-panel"
  class="side-panel"
  role="navigation"
  aria-label="Main navigation"
  aria-hidden="true"
>
  <div class="flex justify-end mb-8">
    <button
      id="close-panel-button"
      class="p-2 rounded-full hover:bg-gray-800 transition-colors duration-200"
      aria-label="Close navigation menu"
      type="button"
    >
      <svg class="h-8 w-8 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>
      </svg>
    </button>
  </div>

  <div class="mb-8">
    <div class="mb-3">
      <p class="text-xs font-semibold uppercase tracking-[0.18em] text-cyan-300/80">Menu</p>
      <h2 class="mt-2 text-2xl font-extrabold text-white">Browse</h2>
    </div>
    <nav class="flex flex-col gap-2" aria-label="Main navigation">
      <a
        href="/"
        class={primaryLinkClass(isHome)}
        aria-current={isHome ? 'page' : undefined}
      >
        <i class="fas fa-home w-5 text-center" aria-hidden="true"></i>
        <span>Home</span>
      </a>
      {primaryLinks.map((link) => (
        <a
          href={link.href}
          class={primaryLinkClass(link.active)}
          role="menuitem"
        >
          <i class={`${link.icon} w-5 text-center`} aria-hidden="true"></i>
          <span>{link.panelLabel ?? link.label}</span>
        </a>
      ))}
    </nav>
  </div>

  <div class="mb-8">
    <div class="mb-3 flex items-center justify-between">
      <h2 class="text-lg font-extrabold text-white">Featured</h2>
      <span class="text-xs uppercase tracking-[0.16em] text-slate-500">Shortcuts</span>
    </div>
    <div class="grid gap-3">
      {featuredLinks.map((link) => (
        <a href={link.href} class={featureCardClass(link.active)}>
          <div class="flex items-start gap-3">
            <span class="inline-flex h-11 w-11 flex-shrink-0 items-center justify-center rounded-xl bg-cyan-500/10 text-cyan-300">
              <i class={link.icon} aria-hidden="true"></i>
            </span>
            <div class="min-w-0">
              <p class="text-[11px] font-semibold uppercase tracking-[0.18em] text-cyan-300/75">{link.eyebrow}</p>
              <h3 class="mt-1 text-base font-bold text-white">{link.title}</h3>
              <p class="mt-1 text-sm leading-6 text-slate-300">{link.description}</p>
            </div>
          </div>
        </a>
      ))}
    </div>
  </div>

  <div class="mt-auto flex justify-center space-x-4 text-gray-400" aria-label="Social media links">
    <SocialIcons />
  </div>
</aside>

<div id="overlay" class="overlay" aria-hidden="true" aria-label="Close navigation menu overlay"></div>
