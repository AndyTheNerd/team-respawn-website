---
import SocialIcons from './SocialIcons.astro';
import {
  aboutLinks,
  hw2GuideSections,
  isNavLinkActive,
  normalizePathname,
  otherProjectSections,
  sidePanelPrimaryLinks,
} from '../data/navigation';

const pathname = Astro.url?.pathname ?? '';
const normalizedPath = normalizePathname(pathname);
const isHome = pathname === '/' || pathname === '/index.html';
const isHw2Stats = normalizedPath === '/halo-wars-stats';
const isVideos = pathname.startsWith('/videos');
const navFlags = { isVideos, isHw2Stats };

const primaryLinks = sidePanelPrimaryLinks.map((link) => ({
  ...link,
  active: isNavLinkActive(link, pathname, navFlags),
}));

const panelOtherProjectSections = otherProjectSections.map((section) => ({
  ...section,
  links: section.links.map((link) => ({
    ...link,
    active: isNavLinkActive(link, pathname, navFlags),
  })),
}));

const panelHw2Sections = hw2GuideSections.map((section) => ({
  ...section,
  links: section.links.map((link) => ({
    ...link,
    active: isNavLinkActive(link, pathname, navFlags),
  })),
}));

const panelAboutLinks = aboutLinks.map((link) => ({
  ...link,
  active: isNavLinkActive(link, pathname, navFlags),
}));

const primaryLinkClass = (active: boolean) =>
  `side-panel-tab-link ${active ? 'side-panel-tab-active' : 'side-panel-tab-inactive'} text-left text-lg font-semibold text-gray-400 hover:text-white transition-all duration-200 py-2 px-3 rounded-lg hover:bg-gray-800/50`;

const sectionLinkClass = (active: boolean) =>
  `text-lg font-semibold transition-all duration-200 py-2 px-3 rounded-lg ${active ? 'side-panel-tab-active' : 'text-gray-400 hover:text-white hover:bg-gray-800/50'}`;
---
<aside
  id="side-panel"
  class="side-panel"
  role="navigation"
  aria-label="Main navigation"
  aria-hidden="true"
>
  <div class="flex justify-end mb-8">
    <button
      id="close-panel-button"
      class="p-2 rounded-full hover:bg-gray-800 transition-colors duration-200"
      aria-label="Close navigation menu"
      type="button"
    >
      <svg class="h-8 w-8 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>
      </svg>
    </button>
  </div>

  <div class="mb-8">
    <h2 class="text-2xl font-extrabold mb-4 text-white">Content</h2>
    <nav class="flex flex-col space-y-2" aria-label="Main content navigation">
      <button
        data-tab-id="home-tab"
        class={`side-panel-tab-link ${isHome ? 'side-panel-tab-active' : 'side-panel-tab-inactive'} text-left text-lg font-semibold text-gray-400 hover:text-white transition-all duration-200 py-2 px-3 rounded-lg hover:bg-gray-800/50`}
        type="button"
        role="menuitem"
      >
        <i class="fas fa-home mr-2" aria-hidden="true"></i>
        Home
      </button>
      {primaryLinks.map((link) => (
        <a
          href={link.href}
          class={primaryLinkClass(link.active)}
          role="menuitem"
        >
          <i class={`${link.icon} mr-2`} aria-hidden="true"></i>
          {link.panelLabel ?? link.label}
        </a>
      ))}
    </nav>
  </div>

  <div class="mb-8">
    <h2 class="text-2xl font-extrabold mb-4 text-white">Other Projects</h2>
    <nav class="flex flex-col space-y-1" aria-label="Other projects navigation">
      {panelOtherProjectSections.map((section, sectionIndex) => (
        <Fragment>
          <p class={`text-xs uppercase tracking-wider text-gray-500 px-3 ${sectionIndex === 0 ? 'pb-1' : 'pt-4 pb-1'}`}>{section.title}</p>
          {section.links.map((link) => (
            <a
              href={link.href}
              target={link.external ? '_blank' : undefined}
              rel={link.external ? 'noopener noreferrer' : undefined}
              class={sectionLinkClass(link.active)}
            >
              <i class={`${link.icon} mr-2`} aria-hidden="true"></i>
              {link.label}
            </a>
          ))}
        </Fragment>
      ))}
    </nav>
  </div>

  <div class="mb-8">
    <h2 class="text-2xl font-extrabold mb-4 text-white">Halo Wars 2</h2>
    <nav class="flex flex-col space-y-1" aria-label="Halo Wars 2 navigation">
      {panelHw2Sections.map((section, sectionIndex) => (
        <Fragment>
          <p class={`text-xs uppercase tracking-wider text-cyan-400/80 px-3 ${sectionIndex === 0 ? 'pb-1' : 'pt-4 pb-1'}`}>{section.panelTitle ?? section.title}</p>
          {section.links.map((link) => (
            <a
              href={link.href}
              class={sectionLinkClass(link.active)}
            >
              <i class={`${link.icon} mr-2`} aria-hidden="true"></i>
              {link.panelLabel ?? link.label}
            </a>
          ))}
        </Fragment>
      ))}
      <p class="text-xs uppercase tracking-wider text-cyan-400/80 px-3 pt-4 pb-1">Tools</p>
      <a
        href="/halo-wars-stats"
        class={sectionLinkClass(isHw2Stats)}
      >
        <i class="fas fa-chart-bar mr-2" aria-hidden="true"></i>
        HW2 Stats
      </a>
    </nav>
  </div>

  <div class="mb-8">
    <h2 class="text-2xl font-extrabold mb-4 text-white">About</h2>
    <nav class="flex flex-col space-y-2" aria-label="About navigation">
      {panelAboutLinks.map((link) => (
        <a
          href={link.href}
          class={primaryLinkClass(link.active)}
          role="menuitem"
        >
          <i class={`${link.icon} mr-2`} aria-hidden="true"></i>
          {link.label}
        </a>
      ))}
    </nav>
  </div>

  <div class="mt-auto flex justify-center space-x-4 text-gray-400" aria-label="Social media links">
    <SocialIcons />
  </div>
</aside>

<div id="overlay" class="overlay" aria-hidden="true" aria-label="Close navigation menu overlay"></div>
