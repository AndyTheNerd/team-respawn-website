---
import { Sidebar } from 'webcoreui/astro'
import RSSButton from './RSSButton.astro'

export interface EvergreenPost {
  title: string
  href: string
}

interface Props {
  categories: string[]
  evergreenPosts: EvergreenPost[]
}

const { categories, evergreenPosts } = Astro.props

const sortedCategories = [...categories].sort((a, b) => a.localeCompare(b))

const sidebarGroups = [
  {
    title: 'Categories',
    items: sortedCategories.map(cat => ({
      name: cat,
      href: `/blog?category=${encodeURIComponent(cat.toLowerCase())}`
    }))
  },
  ...(evergreenPosts.length
    ? [
        {
          title: 'Evergreen guides',
          items: evergreenPosts.map(p => ({
            name: p.title,
            href: p.href
          }))
        }
      ]
    : [])
]
---

<aside class="blog-sidebar blog-index-sidebar">
  <div class="blog-sidebar__scroll space-y-6">
    <Sidebar groups={sidebarGroups} className="blog-categories" />

    <div class="bg-gray-800/50 border border-gray-700 rounded-lg p-4">
      <h3 class="text-sm font-semibold text-white mb-3 flex items-center gap-2">
        <i class="fas fa-rss text-orange-400" aria-hidden="true"></i>
        Stay updated
      </h3>
      <p class="text-xs text-gray-400 mb-3">
        Get the latest guides and walkthroughs delivered to your RSS reader.
      </p>
      <RSSButton variant="default" text="Subscribe via RSS" />
    </div>
  </div>
</aside>

<style>
  .blog-sidebar {
    position: sticky;
    top: 1rem;
    display: flex;
    flex-direction: column;
    max-height: calc(100vh - 2rem);
    gap: 0;
  }

  .blog-sidebar__scroll {
    flex: 1 1 auto;
    min-height: 0;
    overflow-y: auto;
  }

  .blog-sidebar :global(.blog-categories) {
    padding: 1rem;
    background: rgba(30, 41, 59, 0.5);
    border-radius: 0.5rem;
    border: 1px solid rgba(148, 163, 184, 0.1);
  }

  .blog-sidebar :global(.blog-categories strong) {
    color: #f8fafc;
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    margin-bottom: 0.75rem;
    display: block;
  }

  .blog-sidebar :global(.blog-categories ul) {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  .blog-sidebar :global(.blog-categories a) {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.5rem 0.75rem;
    border-radius: 0.375rem;
    color: #94a3b8;
    transition: all 0.2s;
    font-size: 0.875rem;
  }

  .blog-sidebar :global(.blog-categories a:hover) {
    background: rgba(148, 163, 184, 0.1);
    color: #f8fafc;
  }

  .blog-index-sidebar :global(.blog-categories ul + strong) {
    margin-top: 1rem;
  }
</style>
