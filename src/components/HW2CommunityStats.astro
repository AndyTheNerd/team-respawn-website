---
// Displays aggregated HW2 community stats from our D1 database cache.
// Data reflects only matches analyzed through this site (biased sample).
import { mapData } from '../data/haloWars2/maps.ts';

const mapNames: Record<string, string> = Object.fromEntries(
  Object.entries(mapData).map(([id, map]) => [id, map.name])
);
---
<section class="mb-8" aria-labelledby="hw2-community-stats-heading">
  <div class="flex items-center mb-4">
    <h2
      id="hw2-community-stats-heading"
      class="text-lg font-semibold text-gray-200 flex items-center gap-2"
    >
      <i class="fas fa-chart-bar text-cyan-400" aria-hidden="true"></i>
      HW2 Community Insights
    </h2>
  </div>

  <div id="hw2-community-stats" aria-live="polite">
    <!-- Loading skeleton -->
    <div class="animate-pulse space-y-4">
      <div class="grid grid-cols-2 sm:grid-cols-4 gap-3">
        {Array.from({ length: 4 }).map(() => (
          <div class="h-16 bg-gray-800 rounded-xl border border-gray-700/50"></div>
        ))}
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
        {Array.from({ length: 4 }).map(() => (
          <div class="h-36 bg-gray-800 rounded-xl border border-gray-700/50"></div>
        ))}
      </div>
    </div>
  </div>
</section>

<script is:inline define:vars={{ mapNames }}>
  (async () => {
    const container = document.getElementById('hw2-community-stats');
    if (!container) return;

    function fmt(n) {
      return Number(n).toLocaleString('en-US');
    }

    function fmtDuration(seconds) {
      if (!seconds) return '—';
      const m = Math.floor(seconds / 60);
      const s = Math.round(seconds % 60);
      return `${m}m ${String(s).padStart(2, '0')}s`;
    }

    function sectionHeading(label) {
      return `<h3 class="text-xs font-semibold text-gray-400 uppercase tracking-wider mb-2">${label}</h3>`;
    }

    function renderSnapshot(data) {
      const powers = data.medianPowersPerPlayer;
      return `
        <div class="grid grid-cols-2 sm:grid-cols-4 gap-3 mb-5">
          <div class="bg-gray-800/50 border border-gray-700/50 rounded-xl p-3 text-center">
            <div class="text-xl font-bold text-cyan-400">${fmt(data.totalMatches)}</div>
            <div class="text-xs text-gray-500 mt-0.5">Matches Analyzed</div>
          </div>
          <div class="bg-gray-800/50 border border-gray-700/50 rounded-xl p-3 text-center">
            <div class="text-xl font-bold text-cyan-400">${fmt(data.totalPlayers)}</div>
            <div class="text-xs text-gray-500 mt-0.5">Players Tracked</div>
          </div>
          <div class="bg-gray-800/50 border border-gray-700/50 rounded-xl p-3 text-center">
            <div class="text-xl font-bold text-cyan-400">${fmtDuration(data.avgDurationSeconds)}</div>
            <div class="text-xs text-gray-500 mt-0.5">Avg Game Length</div>
          </div>
          <div class="bg-gray-800/50 border border-gray-700/50 rounded-xl p-3 text-center">
            <div class="text-xl font-bold text-cyan-400">${powers != null ? fmt(powers) : '—'}</div>
            <div class="text-xs text-gray-500 mt-0.5">Median Powers Used</div>
          </div>
        </div>
      `;
    }

    function renderMapDurations(stats) {
      if (!stats?.length) return '';
      const maxCnt = stats[0].cnt;
      const rows = stats.map(m => {
        const name = mapNames[m.map_id] || m.map_id.split('\\').pop() || 'Unknown';
        const pct = maxCnt > 0 ? Math.round((m.cnt / maxCnt) * 100) : 0;
        const dur = m.median_seconds ? fmtDuration(m.median_seconds) : '—';
        return `
          <div class="flex items-center gap-2">
            <span class="text-xs text-gray-300 w-24 shrink-0 truncate" title="${name}">${name}</span>
            <div class="flex-1 bg-gray-700 rounded-full h-1.5 overflow-hidden">
              <div class="bg-cyan-500/60 h-full rounded-full" style="width:${pct}%"></div>
            </div>
            <span class="text-xs text-gray-400 w-12 text-right shrink-0">${dur}</span>
            <span class="text-xs text-gray-600 w-6 text-right shrink-0">${m.cnt}</span>
          </div>
        `;
      }).join('');
      return `
        <div>
          ${sectionHeading('Median Duration by Map')}
          <div class="bg-gray-800/40 border border-gray-700/30 rounded-xl p-4 space-y-2">${rows}</div>
        </div>
      `;
    }

    function renderUnits(destroyed, lost) {
      if (destroyed == null && lost == null) return '';
      const maxVal = Math.max(destroyed ?? 0, lost ?? 0, 1);
      const dPct = Math.round(((destroyed ?? 0) / maxVal) * 100);
      const lPct = Math.round(((lost ?? 0) / maxVal) * 100);
      return `
        <div>
          ${sectionHeading('Median Units per Player')}
          <div class="bg-gray-800/40 border border-gray-700/30 rounded-xl p-4 space-y-3">
            <div>
              <div class="flex justify-between text-xs mb-1">
                <span class="text-green-400 font-medium">Units Destroyed</span>
                <span class="text-gray-300 font-bold">${destroyed != null ? fmt(destroyed) : '—'}</span>
              </div>
              <div class="h-2 bg-gray-700 rounded-full overflow-hidden">
                <div class="h-full bg-green-500/70 rounded-full" style="width:${dPct}%"></div>
              </div>
            </div>
            <div>
              <div class="flex justify-between text-xs mb-1">
                <span class="text-red-400 font-medium">Units Lost</span>
                <span class="text-gray-300 font-bold">${lost != null ? fmt(lost) : '—'}</span>
              </div>
              <div class="h-2 bg-gray-700 rounded-full overflow-hidden">
                <div class="h-full bg-red-500/60 rounded-full" style="width:${lPct}%"></div>
              </div>
            </div>
          </div>
        </div>
      `;
    }

    try {
      const res = await fetch('/api/hw2/community-stats');
      if (!res.ok) throw new Error('fetch failed');
      const data = await res.json();

      if (!data.totalMatches) {
        container.innerHTML = '<p class="text-sm text-gray-500 italic">No data yet — stats will appear once players are searched.</p>';
        return;
      }

      container.innerHTML = `
        ${renderSnapshot(data)}
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 mb-4">
          ${renderMapDurations(data.mapDurationStats)}
          ${renderUnits(data.medianUnitsDestroyed, data.medianUnitsLost)}
        </div>
        <p class="text-xs text-gray-600 italic mt-3">
          * Based on matches cached through this site — not representative of the full HW2 player base.
        </p>
      `;
    } catch {
      container.innerHTML = '<p class="text-sm text-gray-500 italic">Could not load community stats.</p>';
    }
  })();
</script>
