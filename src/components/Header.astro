---
import SocialIcons from './SocialIcons.astro';
import SearchBar from './SearchBar.astro';

const { showPanelButton = true } = Astro.props;
const pathname = Astro.url?.pathname ?? '';
const isHome = pathname === '/' || pathname === '/index.html';
const isBlog = pathname.startsWith('/blog');
const isStorehaus = pathname.startsWith('/storehaus') || pathname.startsWith('/storehaus-info');
const isHaloQuotes = false; // external site
const isHw2Stats = pathname.startsWith('/halo-wars-stats');
const isVideos = pathname.startsWith('/videos');
const isOtherProjects = isStorehaus || isHaloQuotes;
const isAbout = pathname.startsWith('/about');
const isSupport = pathname.startsWith('/support');
const isPartner = pathname.startsWith('/partner');
const isAboutSection = isAbout || isSupport || isPartner;
---

<header class="compact-header relative w-full mb-6">
  <div class="header-glass-container compact-header-glass relative w-full px-4 lg:px-6 py-3 rounded-xl overflow-visible">
    <div class="header-content-wrapper relative z-10 flex items-center justify-between gap-4">
      <!-- Left Section: Logo + Hamburger -->
      <div class="flex items-center gap-3 flex-shrink-0">
        <a href="/" aria-label="Return to Team Respawn homepage" class="logo-link inline-block group">
          <img
            src="/content/Team-Respawn-Full.png"
            alt="Team Respawn Logo"
            width="150"
            height="40"
            class="header-logo-compact h-8 sm:h-10 w-auto cursor-pointer transition-all duration-300 group-hover:scale-105 group-hover:drop-shadow-[0_0_12px_rgba(168,85,247,0.6)]"
            loading="eager"
          />
        </a>

        {showPanelButton && (
          <button
            id="open-panel-button"
            data-open-panel
            class="header-menu-btn-compact flex-shrink-0 p-2 rounded-lg backdrop-blur-sm bg-gray-800/40 hover:bg-gray-700/60 border border-white/10 hover:border-purple-400/30 transition-all duration-300 hover:scale-110 group"
            aria-label="Open navigation menu"
            aria-expanded="false"
            aria-controls="side-panel"
            type="button"
          >
            <svg class="h-5 w-5 text-gray-300 group-hover:text-purple-300 transition-colors duration-300" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16m-7 6h7"></path>
            </svg>
          </button>
        )}
      </div>

      <!-- Center Section: Main Navigation (hidden on mobile) -->
      <nav class="hidden lg:flex items-center gap-1 flex-1 justify-center" role="tablist" aria-label="Main navigation">
        <button
          id="home-tab"
          data-tab-link="/"
          role="tab"
          aria-selected={isHome ? "true" : "false"}
          aria-controls="home-content"
          aria-label="View home"
          class={`nav-link ${isHome ? 'nav-link-active' : ''}`}
          type="button"
          tabindex={isHome ? "0" : "-1"}
        >
          Home
        </button>
        <a
          href="/blog"
          class={`nav-link ${isBlog ? 'nav-link-active' : ''}`}
        >
          Blog
        </a>
        <a
          href="/halo-wars-stats"
          class={`nav-link ${isHw2Stats ? 'nav-link-active' : ''}`}
        >
          HW2 Stats
        </a>
        <a
          href="/videos"
          class={`nav-link ${isVideos ? 'nav-link-active' : ''}`}
        >
          Videos
        </a>
        <div class="nav-dropdown" data-dropdown>
          <button
            class={`nav-link nav-dropdown-toggle ${isOtherProjects ? 'nav-link-active' : ''}`}
            type="button"
            aria-expanded="false"
            aria-controls="other-projects-dropdown-menu"
            data-dropdown-toggle
          >
            Other Projects
            <svg class="nav-dropdown-icon h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path>
            </svg>
          </button>
          <div id="other-projects-dropdown-menu" class="nav-dropdown-menu nav-dropdown-menu--rich" role="menu" aria-label="Other projects" data-dropdown-menu>
            <div class="nav-dropdown-rich-grid">
              <!-- Storehaus Bot -->
              <div class="nav-dropdown-section">
                <span class="nav-dropdown-section-heading">Storehaus Bot</span>
                <p class="nav-dropdown-section-desc">Discord bot for HW2, AoE II &amp; IV — stats, player search, and AI strategy.</p>
                <a href="/storehaus-info" class={`nav-dropdown-item nav-dropdown-item--icon ${pathname.startsWith('/storehaus-info') ? 'nav-dropdown-item-active' : ''}`} role="menuitem">
                  <span class="nav-dropdown-item-icon"><i class="fas fa-info-circle" aria-hidden="true"></i></span>
                  Summary
                </a>
                <a href="/storehaus/privacy-policy" class={`nav-dropdown-item nav-dropdown-item--icon ${pathname === '/storehaus/privacy-policy' || pathname === '/storehaus/privacy-policy/' ? 'nav-dropdown-item-active' : ''}`} role="menuitem">
                  <span class="nav-dropdown-item-icon"><i class="fas fa-shield-alt" aria-hidden="true"></i></span>
                  Privacy Policy
                </a>
                <a href="/storehaus/terms-of-service" class={`nav-dropdown-item nav-dropdown-item--icon ${pathname === '/storehaus/terms-of-service' || pathname === '/storehaus/terms-of-service/' ? 'nav-dropdown-item-active' : ''}`} role="menuitem">
                  <span class="nav-dropdown-item-icon"><i class="fas fa-file-contract" aria-hidden="true"></i></span>
                  Terms of Service
                </a>
                <a href="/storehaus" class="nav-dropdown-item nav-dropdown-item--icon" role="menuitem" target="_blank" rel="noopener noreferrer">
                  <span class="nav-dropdown-item-icon"><i class="fab fa-discord" aria-hidden="true"></i></span>
                  Add to Server ↗
                </a>
              </div>
              <!-- Halo Quotes -->
              <div class="nav-dropdown-section">
                <span class="nav-dropdown-section-heading">Halo Quotes</span>
                <p class="nav-dropdown-section-desc">Website, API, and bots for random quotes from the Halo series.</p>
                <a href="https://haloquotes.teamrespawntv.com/" class="nav-dropdown-item nav-dropdown-item--icon" role="menuitem" target="_blank" rel="noopener noreferrer">
                  <span class="nav-dropdown-item-icon"><i class="fas fa-quote-left" aria-hidden="true"></i></span>
                  Website ↗
                </a>
                <a href="https://api.haloquotes.teamrespawntv.com/" class="nav-dropdown-item nav-dropdown-item--icon" role="menuitem" target="_blank" rel="noopener noreferrer">
                  <span class="nav-dropdown-item-icon"><i class="fas fa-code" aria-hidden="true"></i></span>
                  API ↗
                </a>
                <a href="https://github.com/AndyTheNerd/Halo-Quotes" class="nav-dropdown-item nav-dropdown-item--icon" role="menuitem" target="_blank" rel="noopener noreferrer">
                  <span class="nav-dropdown-item-icon"><i class="fab fa-github" aria-hidden="true"></i></span>
                  GitHub ↗
                </a>
              </div>
              <!-- AOE2 API -->
              <div class="nav-dropdown-section">
                <span class="nav-dropdown-section-heading">AOE2 API</span>
                <p class="nav-dropdown-section-desc">Self-hosted REST API serving AoE II civs, units, techs, and structures.</p>
                <a href="https://aoe2api.teamrespawntv.com/" class="nav-dropdown-item nav-dropdown-item--icon" role="menuitem" target="_blank" rel="noopener noreferrer">
                  <span class="nav-dropdown-item-icon"><i class="fas fa-code" aria-hidden="true"></i></span>
                  API ↗
                </a>
                <a href="https://github.com/AndyTheNerd/age-of-empires-II-api" class="nav-dropdown-item nav-dropdown-item--icon" role="menuitem" target="_blank" rel="noopener noreferrer">
                  <span class="nav-dropdown-item-icon"><i class="fab fa-github" aria-hidden="true"></i></span>
                  GitHub ↗
                </a>
              </div>
            </div>
          </div>
        </div>
        <div class="nav-dropdown" data-dropdown>
          <button
            class={`nav-link nav-dropdown-toggle ${isAboutSection ? 'nav-link-active' : ''}`}
            type="button"
            aria-expanded="false"
            aria-controls="about-dropdown-menu"
            data-dropdown-toggle
          >
            About
            <svg class="nav-dropdown-icon h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path>
            </svg>
          </button>
          <div id="about-dropdown-menu" class="nav-dropdown-menu nav-dropdown-menu--rich-sm" role="menu" aria-label="About Team Respawn" data-dropdown-menu>
            <div class="nav-dropdown-rich-grid nav-dropdown-rich-grid--single">
              <div class="nav-dropdown-section">
                <span class="nav-dropdown-section-heading">Team Respawn</span>
                <p class="nav-dropdown-section-desc">RTS strategy content, tools, and community since 2017.</p>
                <a href="/about" class={`nav-dropdown-item nav-dropdown-item--icon ${isAbout ? 'nav-dropdown-item-active' : ''}`} role="menuitem">
                  <span class="nav-dropdown-item-icon"><i class="fas fa-users" aria-hidden="true"></i></span>
                  About Us
                </a>
                <a href="/support" class={`nav-dropdown-item nav-dropdown-item--icon ${isSupport ? 'nav-dropdown-item-active' : ''}`} role="menuitem">
                  <span class="nav-dropdown-item-icon"><i class="fas fa-heart" aria-hidden="true"></i></span>
                  Support Us
                </a>
                <a href="/partner" class={`nav-dropdown-item nav-dropdown-item--icon ${isPartner ? 'nav-dropdown-item-active' : ''}`} role="menuitem">
                  <span class="nav-dropdown-item-icon"><i class="fas fa-handshake" aria-hidden="true"></i></span>
                  Partner with Us
                </a>
              </div>
            </div>
          </div>
        </div>
      </nav>

      <!-- Right Section: Search + Social Icons -->
      <div class="flex items-center gap-2 sm:gap-3 flex-shrink-0">
        <SearchBar />
        <div class="header-social-container-compact hidden xl:block" aria-label="Social media links">
          <SocialIcons compact />
        </div>
      </div>
    </div>
  </div>

  <div role="status" aria-live="polite" aria-atomic="true" class="sr-only" id="tab-announcement"></div>
</header>
