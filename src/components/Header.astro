---
import SocialIcons from './SocialIcons.astro';
import SearchBar from './SearchBar.astro';
import {
  aboutLinks,
  headerPrimaryLinks,
  hw2GuideSections,
  isNavLinkActive,
  normalizePathname,
  otherProjectSections,
  STOREHAUS_INVITE_URL,
} from '../data/navigation';

const { showPanelButton = true } = Astro.props;
const pathname = Astro.url?.pathname ?? '';
const normalizedPath = normalizePathname(pathname);
const isHome = pathname === '/' || pathname === '/index.html';
const isHw2Stats = pathname.startsWith('/halo-wars-stats');
const isVideos = pathname.startsWith('/videos');
const navFlags = { isVideos, isHw2Stats };

const headerPrimaryLinksWithActive = headerPrimaryLinks.map((link) => ({
  ...link,
  active: isNavLinkActive(link, pathname, navFlags),
}));

const headerHw2Sections = hw2GuideSections.map((section) => ({
  ...section,
  links: section.links.map((link) => ({
    ...link,
    active: isNavLinkActive(link, pathname, navFlags),
  })),
}));

const headerOtherProjectSections = otherProjectSections.map((section) => ({
  ...section,
  links: section.links.map((link) => ({
    ...link,
    active: isNavLinkActive(link, pathname, navFlags),
  })),
}));

const headerAboutLinks = aboutLinks.map((link) => ({
  ...link,
  active: isNavLinkActive(link, pathname, navFlags),
}));

const headerAboutSections = [
  {
    title: 'Support and Partnerships',
    description: 'Keep the guides and tools going, or talk with us about sponsorships and collabs.',
    links: headerAboutLinks.filter((link) => normalizePathname(link.href) !== '/about'),
  },
];

const isStorehausRoute =
  normalizedPath === '/storehaus' ||
  normalizedPath === '/storehaus-info' ||
  normalizedPath.startsWith('/storehaus/');
const isOtherProjects = isStorehausRoute || headerOtherProjectSections.some((section) => section.links.some((link) => link.active));
const isAboutSection = headerAboutLinks.some((link) => link.active);
const isHaloWars2Section = isHw2Stats || headerHw2Sections.some((section) => section.links.some((link) => link.active));
const showHaloWars2HeaderDropdown = false;
---

<header class="compact-header relative w-full mb-6">
  <div class="header-glass-container compact-header-glass relative w-full px-4 lg:px-6 py-3 rounded-xl overflow-visible">
    <div class="header-content-wrapper relative z-10 flex items-center justify-between gap-4">
      <!-- Left Section: Logo + Hamburger -->
      <div class="flex items-center gap-3 flex-shrink-0">
        <a href="/" aria-label="Return to Team Respawn homepage" class="logo-link inline-block group">
          <img
            src="/content/Team-Respawn-Full.png"
            alt="Team Respawn Logo"
            width="150"
            height="40"
            class="header-logo-compact h-8 sm:h-10 w-auto cursor-pointer transition-all duration-300 group-hover:scale-105 group-hover:drop-shadow-[0_0_12px_rgba(168,85,247,0.6)]"
            loading="eager"
          />
        </a>

        {showPanelButton && (
          <button
            id="open-panel-button"
            data-open-panel
            class="header-menu-btn-compact flex-shrink-0 p-2 rounded-lg backdrop-blur-sm bg-gray-800/40 hover:bg-gray-700/60 border border-white/10 hover:border-purple-400/30 transition-all duration-300 hover:scale-110 group"
            aria-label="Open navigation menu"
            aria-expanded="false"
            aria-controls="side-panel"
            type="button"
          >
            <svg class="h-5 w-5 text-gray-300 group-hover:text-purple-300 transition-colors duration-300" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16m-7 6h7"></path>
            </svg>
          </button>
        )}
      </div>

      <!-- Center Section: Main Navigation (hidden on mobile) -->
      <nav class="hidden lg:flex items-center gap-1 flex-1 min-w-0 justify-center" role="tablist" aria-label="Main navigation">
        <button
          id="home-tab"
          data-tab-link="/"
          role="tab"
          aria-selected={isHome ? "true" : "false"}
          aria-controls="home-content"
          aria-label="View home"
          class={`nav-link ${isHome ? 'nav-link-active' : ''}`}
          type="button"
          tabindex={isHome ? "0" : "-1"}
        >
          Home
        </button>
        {headerPrimaryLinksWithActive.map((link) => (
          <a
            href={link.href}
            class={`nav-link ${link.active ? 'nav-link-active' : ''}`}
          >
            {link.label}
          </a>
        ))}
        {showHaloWars2HeaderDropdown && (
          <div class="nav-dropdown" data-dropdown>
            <button
              class={`nav-link nav-dropdown-toggle ${isHaloWars2Section ? 'nav-link-active' : ''}`}
              type="button"
              aria-expanded="false"
              aria-controls="halo-wars-2-dropdown-menu"
              data-dropdown-toggle
            >
              Halo Wars 2
              <svg class="nav-dropdown-icon h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path>
              </svg>
            </button>
            <div id="halo-wars-2-dropdown-menu" class="nav-dropdown-menu nav-dropdown-menu--hw2" role="menu" aria-label="Halo Wars 2" data-dropdown-menu>
              <div class="nav-dropdown-hw2-shell">
                <div class="nav-dropdown-hw2-header">
                  <span class="nav-dropdown-hw2-kicker">Franchise Hub</span>
                  <div>
                    <p class="nav-dropdown-hw2-title">Halo Wars 2 Guides, Stats, and Strategy</p>
                    <p class="nav-dropdown-hw2-copy">Jump straight into beginner guides, ranked improvement, leader picks, and the stats tool without digging through the whole site.</p>
                  </div>
                </div>

                <div class="nav-dropdown-hw2-grid">
                  {headerHw2Sections.map((section) => (
                    <div class="nav-dropdown-hw2-zone">
                      <span class="nav-dropdown-hw2-zone-label">{section.headerTitle ?? section.title}</span>
                      <p class="nav-dropdown-hw2-zone-copy">{section.description}</p>
                      {section.chips && section.chips.length > 0 && (
                        <div class="nav-dropdown-hw2-chip-row" aria-hidden="true">
                          {section.chips.map((chip) => (
                            <span class={`nav-dropdown-hw2-chip ${chip.variant === 'banished' ? 'nav-dropdown-hw2-chip--banished' : ''}`}>
                              {chip.label}
                            </span>
                          ))}
                        </div>
                      )}
                      {section.links.map((link) => (
                        <a href={link.href} class={`nav-dropdown-item nav-dropdown-item--icon ${link.active ? 'nav-dropdown-item-active' : ''}`} role="menuitem">
                          <span class="nav-dropdown-item-icon"><i class={link.icon} aria-hidden="true"></i></span>
                          {link.headerLabel ?? link.label}
                        </a>
                      ))}
                    </div>
                  ))}

                  <div class="nav-dropdown-hw2-tools">
                    <span class="nav-dropdown-hw2-tools-kicker">Tools</span>
                    <h3 class="nav-dropdown-hw2-tools-title">HW2 Stats</h3>
                    <p class="nav-dropdown-hw2-tools-copy">Search any gamertag, review CSR, check leader usage, and inspect recent match history in seconds.</p>
                    <div class="nav-dropdown-hw2-tools-list" aria-hidden="true">
                      <span><i class="fas fa-chart-line" aria-hidden="true"></i> CSR lookup</span>
                      <span><i class="fas fa-users" aria-hidden="true"></i> Leader usage</span>
                      <span><i class="fas fa-clock-rotate-left" aria-hidden="true"></i> Recent matches</span>
                    </div>
                    <a href="/halo-wars-stats" class="nav-dropdown-hw2-tools-cta" role="menuitem">
                      Open HW2 Stats
                      <i class="fas fa-arrow-right" aria-hidden="true"></i>
                    </a>
                    <a href="/videos?games=halo-wars-2" class={`nav-dropdown-hw2-tools-secondary ${isVideos ? 'nav-dropdown-hw2-tools-secondary-active' : ''}`} role="menuitem">
                      Browse all HW2 videos
                    </a>
                  </div>
                </div>
              </div>
            </div>
          </div>
        )}
        <div class="nav-dropdown" data-dropdown>
          <button
            class={`nav-link nav-dropdown-toggle ${isOtherProjects ? 'nav-link-active' : ''}`}
            type="button"
            aria-expanded="false"
            aria-controls="other-projects-dropdown-menu"
            data-dropdown-toggle
          >
            Other Projects
            <svg class="nav-dropdown-icon h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path>
            </svg>
          </button>
          <div
            id="other-projects-dropdown-menu"
            class="nav-dropdown-menu nav-dropdown-menu--hub nav-dropdown-menu--hub-projects"
            role="menu"
            aria-label="Other projects"
            data-dropdown-menu
          >
            <div class="nav-dropdown-hub-shell">
              <div class="nav-dropdown-hub-header">
                <span class="nav-dropdown-hub-kicker">Other Projects</span>
                <div>
                  <p class="nav-dropdown-hub-title">Bots, APIs, and Side Builds</p>
                  <p class="nav-dropdown-hub-copy">Explore the tools and experiments around Team Respawn, from the Storehaus Discord bot to utility APIs and Halo quote projects.</p>
                </div>
              </div>

              <div class="nav-dropdown-hub-grid nav-dropdown-hub-grid--projects">
                {headerOtherProjectSections.map((section) => (
                  <div class="nav-dropdown-hub-zone">
                    <span class="nav-dropdown-hub-zone-label">{section.title}</span>
                    <p class="nav-dropdown-hub-zone-copy">{section.description}</p>
                    {section.links.map((link) => (
                      <a
                        href={link.href}
                        class={`nav-dropdown-item nav-dropdown-item--icon ${link.active ? 'nav-dropdown-item-active' : ''}`}
                        role="menuitem"
                        target={link.external ? '_blank' : undefined}
                        rel={link.external ? 'noopener noreferrer' : undefined}
                      >
                        <span class="nav-dropdown-item-icon"><i class={link.icon} aria-hidden="true"></i></span>
                        {link.label}
                      </a>
                    ))}
                  </div>
                ))}

                <div class="nav-dropdown-hub-rail">
                  <span class="nav-dropdown-hub-rail-kicker">Spotlight</span>
                  <h3 class="nav-dropdown-hub-rail-title">Storehaus</h3>
                  <p class="nav-dropdown-hub-rail-copy">The flagship side project: a Discord bot built for RTS players who want instant stats, lookups, and strategy help without leaving chat.</p>
                  <div class="nav-dropdown-hub-rail-list" aria-hidden="true">
                    <span><i class="fab fa-discord" aria-hidden="true"></i> Bot commands and AI answers</span>
                    <span><i class="fas fa-quote-left" aria-hidden="true"></i> Halo quotes and companion APIs</span>
                    <span><i class="fas fa-code" aria-hidden="true"></i> Developer-friendly RTS data</span>
                  </div>
                  <a href="/storehaus" class="nav-dropdown-hub-rail-cta" role="menuitem">
                    Open Storehaus Summary
                    <i class="fas fa-arrow-right" aria-hidden="true"></i>
                  </a>
                  <a
                    href={STOREHAUS_INVITE_URL}
                    class="nav-dropdown-hub-rail-secondary"
                    role="menuitem"
                    target="_blank"
                    rel="noopener noreferrer"
                  >
                    Add Storehaus to Discord
                  </a>
                </div>
              </div>
            </div>
          </div>
        </div>
        <div class="nav-dropdown" data-dropdown>
          <button
            class={`nav-link nav-dropdown-toggle ${isAboutSection ? 'nav-link-active' : ''}`}
            type="button"
            aria-expanded="false"
            aria-controls="about-dropdown-menu"
            data-dropdown-toggle
          >
            About
            <svg class="nav-dropdown-icon h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path>
            </svg>
          </button>
          <div
            id="about-dropdown-menu"
            class="nav-dropdown-menu nav-dropdown-menu--hub nav-dropdown-menu--hub-about"
            role="menu"
            aria-label="About Team Respawn"
            data-dropdown-menu
          >
            <div class="nav-dropdown-hub-shell">
              <div class="nav-dropdown-hub-header">
                <span class="nav-dropdown-hub-kicker">About</span>
                <div>
                  <p class="nav-dropdown-hub-title">Who Team Respawn Is</p>
                  <p class="nav-dropdown-hub-copy">Get the quick version on the team, how we support the site, and how to work with us if there is a genuine fit.</p>
                </div>
              </div>

              <div class="nav-dropdown-hub-grid nav-dropdown-hub-grid--about">
                {headerAboutSections.map((section) => (
                  <div class="nav-dropdown-hub-zone">
                    <span class="nav-dropdown-hub-zone-label">{section.title}</span>
                    <p class="nav-dropdown-hub-zone-copy">{section.description}</p>
                    {section.links.map((link) => (
                      <a href={link.href} class={`nav-dropdown-item nav-dropdown-item--icon ${link.active ? 'nav-dropdown-item-active' : ''}`} role="menuitem">
                        <span class="nav-dropdown-item-icon"><i class={link.icon} aria-hidden="true"></i></span>
                        {link.label}
                      </a>
                    ))}
                  </div>
                ))}

                <div class="nav-dropdown-hub-rail">
                  <span class="nav-dropdown-hub-rail-kicker">Overview</span>
                  <h3 class="nav-dropdown-hub-rail-title">RTS Strategy Since 2017</h3>
                  <p class="nav-dropdown-hub-rail-copy">Team Respawn is built around practical RTS coverage: beginner help, in-depth guides, and tools that save people time.</p>
                  <div class="nav-dropdown-hub-rail-list" aria-hidden="true">
                    <span><i class="fas fa-book-open" aria-hidden="true"></i> Guides, reviews, and walkthroughs</span>
                    <span><i class="fas fa-chart-line" aria-hidden="true"></i> Stats tools and searchable databases</span>
                    <span><i class="fas fa-users" aria-hidden="true"></i> Sponsorships and community projects</span>
                  </div>
                  <a href="/about" class="nav-dropdown-hub-rail-cta" role="menuitem">
                    Meet Team Respawn
                    <i class="fas fa-arrow-right" aria-hidden="true"></i>
                  </a>
                  <a
                    href="/partner"
                    class={`nav-dropdown-hub-rail-secondary ${normalizePathname('/partner') === normalizedPath ? 'nav-dropdown-hub-rail-secondary-active' : ''}`}
                    role="menuitem"
                  >
                    Partner With Us
                  </a>
                </div>
              </div>
            </div>
          </div>
        </div>
      </nav>

      <!-- Right Section: Search + Social Icons -->
      <div class="flex items-center gap-2 sm:gap-3 min-w-0 flex-shrink-0">
        <SearchBar />
        <div class="header-social-container-compact hidden xl:block 2xl:hidden" aria-label="Primary social media links">
          <SocialIcons compact links={['youtube', 'twitch', 'discord']} />
        </div>
        <div class="header-social-container-compact hidden 2xl:block" aria-label="Social media links">
          <SocialIcons compact links={['youtube', 'twitch', 'discord', 'rss', 'shop']} />
        </div>
      </div>
    </div>
  </div>

  <div role="status" aria-live="polite" aria-atomic="true" class="sr-only" id="tab-announcement"></div>
</header>
