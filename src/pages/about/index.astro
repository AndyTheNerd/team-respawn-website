---
import SecondaryPageLayout from '../../layouts/SecondaryPageLayout.astro';
---
<SecondaryPageLayout
  title="About Us | Team Respawn"
  description="Meet Andy and Team Respawn: strategy RTS content for Halo Wars 2, Age of Empires, Age of Mythology, and Halo FPS—YouTube guides, Twitch streams, Discord, and free tools like Halo Wars 2 live stats for casual and competitive players."
  keywords="Team Respawn, about, Andy, RTS gaming, Halo Wars 2 guides, Age of Empires, Age of Mythology, Halo FPS, YouTube gaming"
  canonical="https://www.teamrespawn.net/about"
  ogTitle="About Us | Team Respawn"
  ogDescription="Who we are, what we cover (Halo Wars, AoE, AoM), and how to follow—YouTube, Twitch, Discord, and HW2 stats tools."
  ogImage="https://www.teamrespawn.net/content/Banner.jpg"
>
  <main id="main-content" class="max-w-4xl mx-auto mt-8" aria-label="About Team Respawn">
    <article class="bg-gray-800/60 border border-gray-700/60 rounded-xl overflow-hidden">
      <div class="not-prose">
        <img
          src="/content/team-respawn-banner.jpg"
          alt="Team Respawn — three UNSC Spartans with the Team Respawn logo on a tactical grid background"
          width="1920"
          height="1080"
          class="w-full h-auto block"
          loading="eager"
        />
      </div>
      <div class="p-6 sm:p-8 lg:p-10">
      <header class="mb-8">
        <h1 class="text-4xl sm:text-5xl lg:text-6xl font-extrabold mb-4 text-transparent bg-clip-text bg-gradient-to-r from-purple-400 to-pink-400">
          About Us
        </h1>
        <p class="text-gray-400 text-lg">
          Team Respawn is an RTS gaming content team focused on Halo Wars 2, Age of Empires II, Age of Empires IV, and Age of Mythology.
        </p>
      </header>

      <div class="prose prose-invert prose-lg max-w-none">
        <section class="mb-8">
          <h2 class="text-2xl sm:text-3xl font-bold mb-4 text-purple-300">Who We Are</h2>
          <p class="text-gray-300 leading-relaxed mb-4">
            Founded in 2017, Team Respawn started as a small group of RTS enthusiasts who wanted to create beginner-friendly guides for Halo Wars 2. Since then we've grown into a multi-game content team producing strategy guides, video content, tools, and community resources for the RTS genre.
          </p>
          <p class="text-gray-300 leading-relaxed mb-4">
            Our content spans YouTube videos, written guides, the HW2 Stats player lookup tool, the Storehaus Discord bot, and more. Everything we build is aimed at helping players of all skill levels get more out of their favourite RTS titles.
          </p>
        </section>

        <section class="mb-8">
          <h2 class="text-2xl sm:text-3xl font-bold mb-4 text-purple-300">Our Mission</h2>
          <ul class="list-disc list-inside mb-4 space-y-2 text-gray-300 ml-4">
            <li>Make RTS games more accessible for beginners</li>
            <li>Provide high-quality strategy content for competitive players</li>
            <li>Build free tools that help the community track stats and improve</li>
            <li>Foster a welcoming and active RTS gaming community</li>
          </ul>
        </section>

        <section class="mb-8">
          <h2 class="text-2xl sm:text-3xl font-bold mb-4 text-purple-300">What We Cover</h2>
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
            <div class="bg-gray-800/60 p-4 rounded-lg border border-gray-700/60 hover:border-purple-500/40 transition-colors duration-300">
              <i class="fas fa-gamepad text-purple-400 text-2xl mb-2" aria-hidden="true"></i>
              <h3 class="font-semibold text-purple-200 mb-1">Halo Wars 2</h3>
              <p class="text-sm text-gray-400">Leader guides, strategy, match stats, and community tools</p>
            </div>
            <div class="bg-gray-800/60 p-4 rounded-lg border border-gray-700/60 hover:border-purple-500/40 transition-colors duration-300">
              <i class="fas fa-chess-rook text-purple-400 text-2xl mb-2" aria-hidden="true"></i>
              <h3 class="font-semibold text-purple-200 mb-1">Age of Empires</h3>
              <p class="text-sm text-gray-400">Civilization guides, build orders, and tips for AoE II, IV, and Mythology</p>
            </div>
          </div>
        </section>

        <section class="not-prose">
          <div class="relative overflow-hidden rounded-xl border border-red-900/40 bg-gradient-to-br from-red-950/50 via-gray-900/80 to-gray-900/60 p-6 sm:p-8">
            <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_top_right,_rgba(239,68,68,0.08)_0%,_transparent_60%)] pointer-events-none" aria-hidden="true"></div>
            <div class="relative flex flex-col sm:flex-row items-start sm:items-center gap-5">
              <div class="flex-shrink-0 flex items-center justify-center w-14 h-14 rounded-full bg-red-600/15 border border-red-500/30">
                <i class="fab fa-youtube text-red-500 text-2xl" aria-hidden="true"></i>
              </div>
              <div class="flex-1 min-w-0">
                <h2 class="text-xl sm:text-2xl font-bold text-white mb-1">Watch on YouTube</h2>
                <p class="text-gray-400 text-sm sm:text-base leading-relaxed">
                  Strategy guides, leader breakdowns, walkthroughs, and more — all free on the channel. Subscribe to catch new videos as they drop.
                </p>
              </div>
              <a
                href="https://www.youtube.com/@TeamRespawn"
                target="_blank"
                rel="noopener noreferrer"
                class="flex-shrink-0 inline-flex items-center gap-2 px-5 py-2.5 rounded-lg bg-red-600 hover:bg-red-500 text-white font-semibold text-sm transition-colors duration-200 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-red-500"
              >
                <i class="fab fa-youtube" aria-hidden="true"></i>
                Subscribe
              </a>
            </div>
          </div>
        </section>
      </div>
      </div>
    </article>
  </main>
</SecondaryPageLayout>
