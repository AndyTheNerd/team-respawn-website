---
import SecondaryPageLayout from '../../layouts/SecondaryPageLayout.astro';
---
<SecondaryPageLayout
  title="About Us | Team Respawn"
  description="Learn about Team Respawn — who we are, what we do, and our mission in the RTS gaming community."
  keywords="Team Respawn, about, RTS community, gaming team, Halo Wars 2"
  canonical="https://www.teamrespawn.net/about"
  ogTitle="About Us | Team Respawn"
  ogDescription="Learn about Team Respawn — who we are, what we do, and our mission in the RTS gaming community."
  ogImage="https://www.teamrespawn.net/content/Banner.jpg"
>
  <main id="main-content" class="max-w-4xl mx-auto mt-8" aria-label="About Team Respawn">
    <article class="bg-gray-800/60 border border-gray-700/60 rounded-xl p-6 sm:p-8 lg:p-10">
      <header class="mb-8">
        <h1 class="text-4xl sm:text-5xl lg:text-6xl font-extrabold mb-4 text-transparent bg-clip-text bg-gradient-to-r from-purple-400 to-pink-400">
          About Us
        </h1>
        <p class="text-gray-400 text-lg">
          Team Respawn is an RTS gaming content team focused on Halo Wars 2, Age of Empires II, Age of Empires IV, and Age of Mythology.
        </p>
      </header>

      <div class="prose prose-invert prose-lg max-w-none">
        <section class="mb-8">
          <h2 class="text-2xl sm:text-3xl font-bold mb-4 text-purple-300">Who We Are</h2>
          <p class="text-gray-300 leading-relaxed mb-4">
            Founded in 2017, Team Respawn started as a small group of RTS enthusiasts who wanted to create beginner-friendly guides for Halo Wars 2. Since then we've grown into a multi-game content team producing strategy guides, video content, tools, and community resources for the RTS genre.
          </p>
          <p class="text-gray-300 leading-relaxed mb-4">
            Our content spans YouTube videos, written guides, the HW2 Stats player lookup tool, the Storehaus Discord bot, and more. Everything we build is aimed at helping players of all skill levels get more out of their favourite RTS titles.
          </p>
        </section>

        <section class="mb-8">
          <h2 class="text-2xl sm:text-3xl font-bold mb-4 text-purple-300">Our Mission</h2>
          <ul class="list-disc list-inside mb-4 space-y-2 text-gray-300 ml-4">
            <li>Make RTS games more accessible for beginners</li>
            <li>Provide high-quality strategy content for competitive players</li>
            <li>Build free tools that help the community track stats and improve</li>
            <li>Foster a welcoming and active RTS gaming community</li>
          </ul>
        </section>

        <section class="mb-8">
          <h2 class="text-2xl sm:text-3xl font-bold mb-4 text-purple-300">What We Cover</h2>
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
            <div class="bg-gray-800/60 p-4 rounded-lg border border-gray-700/60 hover:border-purple-500/40 transition-colors duration-300">
              <i class="fas fa-gamepad text-purple-400 text-2xl mb-2" aria-hidden="true"></i>
              <h3 class="font-semibold text-purple-200 mb-1">Halo Wars 2</h3>
              <p class="text-sm text-gray-400">Leader guides, strategy, match stats, and community tools</p>
            </div>
            <div class="bg-gray-800/60 p-4 rounded-lg border border-gray-700/60 hover:border-purple-500/40 transition-colors duration-300">
              <i class="fas fa-chess-rook text-purple-400 text-2xl mb-2" aria-hidden="true"></i>
              <h3 class="font-semibold text-purple-200 mb-1">Age of Empires</h3>
              <p class="text-sm text-gray-400">Civilization guides, build orders, and tips for AoE II, IV, and Mythology</p>
            </div>
          </div>
        </section>
      </div>
    </article>
  </main>
</SecondaryPageLayout>
