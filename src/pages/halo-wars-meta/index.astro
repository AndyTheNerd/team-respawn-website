---
import HW2GlobalSnapshot from '../../components/HW2GlobalSnapshot.astro';
import HW2HubNav from '../../components/HW2HubNav.astro';
import SecondaryPageLayout from '../../layouts/SecondaryPageLayout.astro';
---

<SecondaryPageLayout
  title="Halo Wars 2 Meta Snapshot - Team Respawn"
  description="Browse scheduled Halo Wars 2 aggregate playlist meta snapshots, including leader usage, map trends, and ranked playlist overview data."
  keywords="Halo Wars 2 meta, HW2 meta snapshot, Halo Wars 2 leader usage, Halo Wars 2 map stats"
  canonical="https://www.teamrespawn.net/halo-wars-meta/"
  ogTitle="Halo Wars 2 Meta Snapshot - Team Respawn"
  ogDescription="Scheduled aggregate Halo Wars 2 playlist meta snapshots with source-labelled global data."
>
  <main id="main-content">
    <section class="mb-8 rounded-xl border border-cyan-500/20 bg-gradient-to-br from-slate-950 via-slate-900 to-cyan-950/40 px-6 py-10">
      <p class="text-sm uppercase tracking-[0.2em] text-cyan-300">Halo Wars 2</p>
      <h1 class="mt-3 text-3xl font-bold text-slate-100 sm:text-4xl">Meta Snapshot</h1>
      <p class="mt-4 max-w-3xl text-base text-slate-300">
        This page only shows scheduled aggregate data. It is intentionally separate from the player lookup cache so public meta claims are tied to a labelled snapshot source.
      </p>
    </section>

    <HW2HubNav current="meta" />

    <HW2GlobalSnapshot rootId="hw2-meta-page" mode="summary" />
  </main>
</SecondaryPageLayout>
