---
import SecondaryPageLayout from '../../layouts/SecondaryPageLayout.astro';
import BlogCard from '../../components/BlogCard/BlogCard.astro';
import BlogIndexSidebar from '../../components/BlogIndexSidebar.astro';
import { Input, Select } from 'webcoreui/astro';
import blogPosts from '../../data/blogPosts.js';
import { evergreenBlogPostHrefs } from '../../data/evergreenBlogPosts.js';
import { absoluteBlogCardImageUrl } from '../../utils/blogImageUrl';
import '../../styles/webcore.scss';
import '../../styles/blog-overrides.scss';

// Listing: all posts ship in HTML; filters + pagination run client-side (see /public/js/blog-search.js).

// Pagination settings (handled client-side)
const pageSize = 12;
const sortedPosts = [...blogPosts].sort((a, b) => {
  // Featured posts always come first
  if (a.featured && !b.featured) return -1;
  if (!a.featured && b.featured) return 1;

  // Then sort by date (newest first)
  const aDate = a.dateIso ? Date.parse(a.dateIso) : 0;
  const bDate = b.dateIso ? Date.parse(b.dateIso) : 0;
  return bDate - aDate;
});

// Get unique categories for filter
const categories = [...new Set(blogPosts.map(post => post.category))];
const categoryItems = [
  { name: 'All Categories', value: 'all' },
  ...categories.map(cat => ({ name: cat, value: cat }))
];

const tags = [
  ...new Set(
    blogPosts.reduce((acc, post) => {
      if (post.tags?.length) {
        acc.push(...post.tags);
      }
      return acc;
    }, [])
  )
].sort((a, b) => a.localeCompare(b));
const tagItems = [
  { name: 'All Tags', value: 'all' },
  ...tags.map(tag => ({ name: tag, value: tag }))
];

const sortItems = [
  { name: 'Newest', value: 'newest' },
  { name: 'Oldest', value: 'oldest' },
  { name: 'Title A-Z', value: 'title-asc' },
  { name: 'Title Z-A', value: 'title-desc' }
];

const postByHref = new Map(blogPosts.map((post) => [post.href, post]));
const evergreenPosts = evergreenBlogPostHrefs.flatMap((href) => {
  const post = postByHref.get(href);
  return post ? [{ title: post.title, href: post.href }] : [];
});

// Enhanced meta description
const metaDescription = `Team Respawn Blog: ${blogPosts.length}+ gaming guides and strategy articles for Halo Wars, Age of Empires, and Age of Mythology. Master your favorite strategy games with expert tips, walkthroughs, and in-depth guides.`;

// Blog structured data
const blogStructuredData = {
  "@context": "https://schema.org",
  "@type": "Blog",
  "name": "Team Respawn Blog",
  "description": metaDescription,
  "url": "https://www.teamrespawn.net/blog",
  "author": {
    "@type": "Organization",
    "name": "Team Respawn",
    "url": "https://www.teamrespawn.net"
  },
  "publisher": {
    "@type": "Organization",
    "name": "Team Respawn",
    "logo": {
      "@type": "ImageObject",
      "url": "https://www.teamrespawn.net/content/Team-Respawn-Full.png"
    }
  },
  "blogPost": sortedPosts.slice(0, 10).map(post => ({
    "@type": "BlogPosting",
    "headline": post.title,
    "description": post.excerpt,
    "url": `https://www.teamrespawn.net${post.href}`,
    "datePublished": post.dateIso,
    "author": {
      "@type": "Organization",
      "name": "Team Respawn"
    },
    "publisher": {
      "@type": "Organization",
      "name": "Team Respawn"
    },
    "image": absoluteBlogCardImageUrl(post.img),
    "about": post.tags?.map(tag => ({
      "@type": "Thing",
      "name": tag
    }))
  }))
};
---
<SecondaryPageLayout
  title="Team Respawn Blog | Gaming Guides & Strategy Articles"
  description={metaDescription}
  canonical="https://www.teamrespawn.net/blog"
  ogTitle="Team Respawn Blog"
  ogDescription={metaDescription}
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(blogStructuredData)} />
  </Fragment>

  <div class="w-full flex flex-col lg:flex-row gap-8 pt-8">
    <main id="main-content" class="flex-1 min-w-0 w-full">
    <!-- Search and Filter Section -->
    <div class="blog-search-filter mb-8 bg-gray-800/50 border border-gray-700 rounded-lg p-4 sm:p-6">
      <div class="flex flex-col lg:flex-row gap-4">
        <div class="flex-1">
          <Input
            type="search"
            id="blog-search"
            placeholder="Search articles..."
            className="w-full"
          />
        </div>
        <div class="sm:w-48">
          <Select
            name="category-filter"
            placeholder="All Categories"
            itemGroups={[{ items: categoryItems }]}
          />
        </div>
        <div class="sm:w-48">
          <Select
            name="tag-filter"
            placeholder="All Tags"
            itemGroups={[{ items: tagItems }]}
          />
        </div>
        <div class="sm:w-40">
          <Select
            name="sort-filter"
            placeholder="Newest"
            itemGroups={[{ items: sortItems }]}
          />
        </div>
      </div>
      <div id="blog-active-filters" class="blog-active-filters">
        <span class="blog-active-label">Active filters</span>
        <div id="blog-active-filter-list" class="blog-active-list" aria-live="polite"></div>
        <div class="blog-controls-row">
          <label class="blog-featured-toggle">
            <input type="checkbox" id="featured-toggle" checked>
            <span class="checkmark"></span>
            <span>⭐ Featured</span>
          </label>
          <button id="blog-clear-filters" class="blog-active-clear" type="button">
            Clear
          </button>
        </div>
      </div>
    </div>

    <!-- Latest Articles Section -->
    <div class="mb-8">
      <h2 class="text-2xl font-bold text-white">Latest Articles</h2>
    </div>

    <div id="blog-grid" class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
      {sortedPosts.map((post) => (
        <div
          class="blog-card-wrapper"
          data-title={post.title.toLowerCase()}
          data-category={post.category}
          data-excerpt={post.excerpt.toLowerCase()}
          data-tags={(post.tags || []).join('|').toLowerCase()}
          data-date={post.dateIso}
          data-featured={post.featured ? 'true' : 'false'}
          data-featured-enabled="true"
        >
          <BlogCard
            href={post.href}
            img={post.img}
            title={post.title}
            dateIso={post.dateIso}
            text={`<span class="blog-category">${post.category}</span><br/>${post.excerpt}`}
            featured={post.featured}
          />
        </div>
      ))}
    </div>

    <!-- No results message -->
    <div id="no-results" class="hidden text-center py-12">
      <p class="text-xl text-gray-400">No articles found matching your criteria.</p>
    </div>

    <!-- Pagination (rendered client-side) -->
    <nav id="blog-pagination" class="mt-12 flex justify-center" aria-label="Blog pagination">
      <div id="pagination-controls" class="inline-flex flex-wrap items-center gap-2"></div>
    </nav>
    </main>

    <div class="lg:w-64 lg:flex-shrink-0">
      <BlogIndexSidebar categories={categories} evergreenPosts={evergreenPosts} />
    </div>
  </div>

  <Fragment slot="scripts">
    <script define:vars={{ pageSize }}>
      window.blogPageSize = pageSize;
    </script>
    <script src="/js/blog-search.js" is:inline></script>
  </Fragment>
</SecondaryPageLayout>
