<BlogPostLayout
  title="Gears of War: Ultimate Edition Full Campaign Walkthrough"
  description="A full walkthrough of Gears of War: Ultimate Edition. Watch the complete campaign run below."
  category="Walkthroughs"
  tags={['Gears of War']}
  publishedDate="Published on February 7, 2026"
  dateIso="2026-02-07"
