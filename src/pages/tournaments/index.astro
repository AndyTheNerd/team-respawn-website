---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import SidePanel from '../../components/SidePanel.astro';
---
<BaseLayout
  title="HW2 Tournaments - Team Respawn"
  description="Browse and join community Halo Wars 2 tournaments. Create your own bracket and invite players."
  keywords="Halo Wars 2 tournament, HW2 bracket, community tournament, Halo Wars 2 competition"
  canonical="https://www.teamrespawn.net/tournaments/"
  ogTitle="HW2 Tournaments - Team Respawn"
  ogDescription="Browse and join community Halo Wars 2 tournaments, or create your own bracket."
  ogImage="https://www.teamrespawn.net/content/Team-Respawn-Full.png"
>
  <div class="container mx-auto p-4 sm:p-8">
    <Header />

    <main id="main-content" class="mx-auto max-w-5xl px-4 py-10">
      <div class="mb-6 flex items-center justify-between gap-4 flex-wrap">
        <div>
          <div class="flex items-center gap-3 flex-wrap">
            <h1 class="text-2xl font-bold text-white">HW2 Tournaments</h1>
            <span
              class="inline-flex shrink-0 items-center rounded-md border border-violet-400/40 bg-violet-500/15 px-2 py-0.5 text-[10px] font-bold uppercase tracking-wider text-violet-200"
              title="This tournament tool is in beta; behavior may change as we improve it."
            >Beta</span>
          </div>
          <p class="mt-1 text-sm text-gray-400">Community-run single and double elimination brackets.</p>
        </div>
        <a
          href="/tournaments/create"
          class="inline-flex items-center gap-2 rounded-md border border-cyan-500/40 bg-cyan-500/10 px-4 py-2 text-sm font-semibold text-cyan-300 hover:bg-cyan-500/20 hover:border-cyan-400/60 transition-colors"
        >
          <i class="fas fa-plus" aria-hidden="true"></i>
          Create Tournament
        </a>
      </div>

      <!-- Filter tabs + search -->
      <div class="mb-5 flex items-center gap-4 flex-wrap">
        <div class="flex gap-1 rounded-lg border border-slate-700/40 bg-slate-800/30 p-1">
          {[
            { key: 'all', label: 'All' },
            { key: 'registration', label: 'Open' },
            { key: 'active', label: 'In Progress' },
            { key: 'completed', label: 'Completed' },
          ].map(tab => (
            <button
              type="button"
              class={`filter-tab rounded-md px-3 py-1.5 text-xs font-medium transition-colors ${tab.key === 'all' ? 'bg-slate-700/80 text-white active-tab' : 'text-gray-400 hover:text-gray-200'}`}
              data-filter={tab.key}
            >
              {tab.label}
            </button>
          ))}
        </div>
        <input
          id="search-input" type="search" placeholder="Search by name or organizer…"
          class="flex-1 min-w-40 max-w-xs rounded-md border border-slate-700/40 bg-slate-800/30 px-3 py-1.5 text-xs text-gray-200 placeholder-gray-500 focus:border-slate-600/60 focus:outline-none"
        />
      </div>

      <!-- Skeleton -->
      <div id="tournament-list-skeleton" class="space-y-3">
        {Array.from({ length: 4 }).map(() => (
          <div class="animate-pulse rounded-lg border border-slate-700/40 bg-slate-800/30 p-4 h-20"></div>
        ))}
      </div>

      <div id="tournament-list" class="hidden space-y-3"></div>
      <p id="tournament-empty" class="hidden text-center text-sm text-gray-500 py-12">No tournaments found.</p>
      <p id="tournament-error" class="hidden text-center text-sm text-red-400 py-12"></p>
    </main>

    <Footer />
  </div>

  <SidePanel />
</BaseLayout>

<script>
  let allTournaments: any[] = [];
  let activeFilter = 'all';
  let searchQuery = '';

  const listEl = document.getElementById('tournament-list')!;
  const skeletonEl = document.getElementById('tournament-list-skeleton')!;
  const emptyEl = document.getElementById('tournament-empty')!;
  const errorEl = document.getElementById('tournament-error')!;
  const searchInput = document.getElementById('search-input') as HTMLInputElement;

  function escHtml(str: string): string {
    return str.replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;').replace(/"/g, '&quot;');
  }

  function renderCard(t: any): string {
    const statusBadge: Record<string, string> = {
      registration: '<span class="rounded-full bg-blue-500/20 px-2 py-0.5 text-[10px] font-semibold uppercase tracking-wide text-blue-300">Open</span>',
      active: '<span class="rounded-full bg-yellow-500/20 px-2 py-0.5 text-[10px] font-semibold uppercase tracking-wide text-yellow-300">In Progress</span>',
      completed: '<span class="rounded-full bg-gray-500/20 px-2 py-0.5 text-[10px] font-semibold uppercase tracking-wide text-gray-400">Completed</span>',
    };
    const formatLabel = t.format === 'double_elimination' ? 'Double Elim' : 'Single Elim';
    const privacyIcon = t.is_private
      ? '<i class="fas fa-lock text-amber-400 text-xs ml-1" title="Private — password required to join"></i>'
      : '';
    const expires = new Date(t.expires_at).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' });
    const statusClass = t.status === 'completed' ? 'opacity-60' : '';

    return `
      <a href="/tournaments/tournament?id=${encodeURIComponent(t.id)}" class="flex items-center gap-4 rounded-lg border border-slate-700/40 bg-slate-800/30 p-4 hover:bg-slate-700/30 hover:border-slate-600/50 transition-colors ${statusClass}">
        <div class="flex-1 min-w-0">
          <div class="flex items-center gap-2 flex-wrap">
            <span class="font-semibold text-white truncate">${escHtml(t.name)}</span>
            ${statusBadge[t.status as string] ?? ''}
            ${privacyIcon}
          </div>
          <div class="mt-1 flex items-center gap-3 text-xs text-gray-400 flex-wrap">
            <span>by ${escHtml(t.organizer_name)}</span>
            <span>· ${formatLabel}</span>
            <span>· ${t.participant_count} / ${t.max_participants} players</span>
            <span class="text-gray-500">· expires ${expires}</span>
          </div>
        </div>
        <i class="fas fa-chevron-right text-gray-500 flex-shrink-0" aria-hidden="true"></i>
      </a>
    `;
  }

  function applyFilters() {
    const q = searchQuery.toLowerCase();
    const filtered = allTournaments.filter(t => {
      const matchesStatus = activeFilter === 'all' || t.status === activeFilter;
      const matchesSearch = !q ||
        t.name.toLowerCase().includes(q) ||
        t.organizer_name.toLowerCase().includes(q);
      return matchesStatus && matchesSearch;
    });

    if (filtered.length === 0) {
      listEl.classList.add('hidden');
      emptyEl.classList.remove('hidden');
    } else {
      emptyEl.classList.add('hidden');
      listEl.innerHTML = filtered.map(renderCard).join('');
      listEl.classList.remove('hidden');
    }
  }

  // Filter tabs
  document.querySelectorAll('.filter-tab').forEach(tab => {
    tab.addEventListener('click', () => {
      document.querySelectorAll('.filter-tab').forEach(t => {
        t.classList.remove('bg-slate-700/80', 'text-white', 'active-tab');
        t.classList.add('text-gray-400');
      });
      tab.classList.add('bg-slate-700/80', 'text-white', 'active-tab');
      tab.classList.remove('text-gray-400');
      activeFilter = (tab as HTMLElement).dataset.filter!;
      applyFilters();
    });
  });

  // Search
  searchInput.addEventListener('input', () => {
    searchQuery = searchInput.value.trim();
    applyFilters();
  });

  async function loadTournaments() {
    try {
      const res = await fetch('/api/tournaments');
      const data = await res.json();

      skeletonEl.classList.add('hidden');

      if (!res.ok) {
        errorEl.textContent = data.error ?? 'Failed to load tournaments.';
        errorEl.classList.remove('hidden');
        return;
      }

      allTournaments = data.tournaments ?? [];
      applyFilters();
    } catch {
      skeletonEl.classList.add('hidden');
      errorEl.textContent = 'Failed to load tournaments. Please try again.';
      errorEl.classList.remove('hidden');
    }
  }

  loadTournaments();
</script>
