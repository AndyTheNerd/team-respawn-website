---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import SidePanel from '../../components/SidePanel.astro';
---
<BaseLayout
  title="Create Tournament - Team Respawn"
  description="Create a Halo Wars 2 community tournament bracket."
  canonical="https://www.teamrespawn.net/tournaments/create"
>
  <div class="container mx-auto p-4 sm:p-8">
    <Header />

    <main id="main-content" class="mx-auto max-w-2xl px-4 py-10">
      <div class="mb-6">
        <a href="/tournaments" class="text-xs text-cyan-400 hover:text-cyan-300 transition-colors">
          <i class="fas fa-arrow-left mr-1" aria-hidden="true"></i>All Tournaments
        </a>
        <h1 class="mt-3 text-2xl font-bold text-white">Create a Tournament</h1>
        <p class="mt-1 text-sm text-gray-400">
          Set an admin password to manage your bracket. You'll use it to start the tournament and record results.
        </p>
      </div>

      <!-- Create form -->
      <form id="create-form" class="space-y-5">
        <div>
          <label class="block text-sm font-medium text-gray-300 mb-1.5" for="t-name">Tournament Name</label>
          <input
            id="t-name" name="name" type="text" required maxlength="80" autocomplete="off"
            placeholder="e.g. Weekend Warriors #3"
            class="w-full rounded-md border border-slate-600/50 bg-slate-800/60 px-3 py-2 text-sm text-white placeholder-gray-500 focus:border-cyan-500/60 focus:outline-none"
          />
        </div>

        <div>
          <label class="block text-sm font-medium text-gray-300 mb-1.5" for="t-organizer">Your Name / Handle</label>
          <input
            id="t-organizer" name="organizerName" type="text" required maxlength="50" autocomplete="off"
            placeholder="e.g. Andy"
            class="w-full rounded-md border border-slate-600/50 bg-slate-800/60 px-3 py-2 text-sm text-white placeholder-gray-500 focus:border-cyan-500/60 focus:outline-none"
          />
        </div>

        <div class="grid grid-cols-2 gap-4">
          <div>
            <label class="block text-sm font-medium text-gray-300 mb-1.5" for="t-format">Format</label>
            <select
              id="t-format" name="format"
              class="w-full rounded-md border border-slate-600/50 bg-slate-800/60 px-3 py-2 text-sm text-white focus:border-cyan-500/60 focus:outline-none"
            >
              <option value="single_elimination">Single Elimination</option>
              <option value="double_elimination">Double Elimination</option>
            </select>
          </div>
          <div>
            <label class="block text-sm font-medium text-gray-300 mb-1.5" for="t-max">Max Players</label>
            <input
              id="t-max" name="maxParticipants" type="number" min="2" max="64" value="16"
              class="w-full rounded-md border border-slate-600/50 bg-slate-800/60 px-3 py-2 text-sm text-white focus:border-cyan-500/60 focus:outline-none"
            />
          </div>
        </div>

        <div>
          <label class="block text-sm font-medium text-gray-300 mb-1.5" for="t-admin-pw">
            Admin Password
            <span class="text-gray-500 font-normal">(min 6 characters)</span>
          </label>
          <input
            id="t-admin-pw" name="adminPassword" type="password" required minlength="6" autocomplete="new-password"
            placeholder="Remember this — you'll need it to manage the bracket"
            class="w-full rounded-md border border-slate-600/50 bg-slate-800/60 px-3 py-2 text-sm text-white placeholder-gray-500 focus:border-cyan-500/60 focus:outline-none"
          />
          <p class="mt-1 text-xs text-gray-500">
            Used to start the tournament, record results, and override matches. No link to save — just the password.
          </p>
        </div>

        <div class="rounded-md border border-slate-700/40 bg-slate-800/20 p-4 space-y-3">
          <div class="flex items-center gap-2">
            <input
              id="t-private" name="isPrivate" type="checkbox"
              class="rounded border-slate-600 bg-slate-800 text-cyan-500 focus:ring-cyan-500/40"
            />
            <label for="t-private" class="text-sm text-gray-300 cursor-pointer">Private tournament (password to join)</label>
          </div>
          <div id="join-pw-wrapper" class="hidden">
            <label class="block text-sm font-medium text-gray-300 mb-1.5" for="t-join-pw">Join Password</label>
            <input
              id="t-join-pw" name="joinPassword" type="text" autocomplete="off"
              placeholder="Share with invited players"
              class="w-full rounded-md border border-slate-600/50 bg-slate-800/60 px-3 py-2 text-sm text-white placeholder-gray-500 focus:border-cyan-500/60 focus:outline-none"
            />
          </div>
        </div>

        <p id="create-error" class="hidden text-sm text-red-400"></p>

        <button
          type="submit" id="submit-btn"
          class="w-full rounded-md border border-cyan-500/40 bg-cyan-500/10 px-4 py-2.5 text-sm font-semibold text-cyan-300 hover:bg-cyan-500/20 hover:border-cyan-400/60 transition-colors disabled:opacity-50 disabled:cursor-not-allowed"
        >
          Create Tournament
        </button>
      </form>
    </main>

    <Footer />
  </div>

  <SidePanel />
</BaseLayout>

<script>
  const isPrivateCheckbox = document.getElementById('t-private') as HTMLInputElement;
  const joinPwWrapper = document.getElementById('join-pw-wrapper')!;

  isPrivateCheckbox.addEventListener('change', () => {
    joinPwWrapper.classList.toggle('hidden', !isPrivateCheckbox.checked);
  });

  const form = document.getElementById('create-form') as HTMLFormElement;
  const submitBtn = document.getElementById('submit-btn') as HTMLButtonElement;
  const errorEl = document.getElementById('create-error')!;

  form.addEventListener('submit', async (e) => {
    e.preventDefault();
    errorEl.classList.add('hidden');
    submitBtn.disabled = true;
    submitBtn.textContent = 'Creating…';

    const data = new FormData(form);
    const adminPassword = (data.get('adminPassword') as string) ?? '';
    const body: Record<string, unknown> = {
      name: data.get('name'),
      organizerName: data.get('organizerName'),
      adminPassword,
      format: data.get('format'),
      maxParticipants: Number(data.get('maxParticipants')),
    };
    const joinPw = (data.get('joinPassword') as string)?.trim();
    if (isPrivateCheckbox.checked && joinPw) body.joinPassword = joinPw;

    try {
      const res = await fetch('/api/tournaments', {
        method: 'POST',
        headers: { 'content-type': 'application/json' },
        body: JSON.stringify(body),
      });
      const json = await res.json();

      if (!res.ok) {
        errorEl.textContent = json.error ?? 'Failed to create tournament.';
        errorEl.classList.remove('hidden');
        submitBtn.disabled = false;
        submitBtn.textContent = 'Create Tournament';
        return;
      }

      const { id } = json;

      // Cache the admin password so the new page can auto-activate admin mode
      sessionStorage.setItem(`trn_admin_${id}`, adminPassword);

      // Redirect directly to the tournament page — admin panel will auto-unlock
      window.location.href = `/tournaments/tournament?id=${id}`;
    } catch {
      errorEl.textContent = 'Network error. Please try again.';
      errorEl.classList.remove('hidden');
      submitBtn.disabled = false;
      submitBtn.textContent = 'Create Tournament';
    }
  });
</script>
