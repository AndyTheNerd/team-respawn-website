            <div class="mt-2 flex gap-2 flex-wrap">
              <button type="button" class="override-btn flex-1 rounded border border-amber-500/30 bg-amber-500/10 px-3 py-2 text-xs text-amber-300 hover:bg-amber-500/20 transition-colors" data-winner="${esc(p1Name)}">
                Force ${esc(p1Name)} (override)
              </button>
              <button type="button" class="override-btn flex-1 rounded border border-amber-500/30 bg-amber-500/10 px-3 py-2 text-xs text-amber-300 hover:bg-amber-500/20 transition-colors" data-winner="${esc(p2Name)}">
                Force ${esc(p2Name)} (override)
              </button>
            </div>
          </details>

          <p class="match-msg hidden text-xs"></p>
        </div>
      `;
    }).join('');

    // Wire suggest buttons
    list.querySelectorAll('.suggest-btn').forEach(btn => {
      btn.addEventListener('click', async () => {
        const card = btn.closest('[data-brackets-match-id]');
        const bMatchId = Number(card.dataset.bracketsMatchId);
        const suggestionsEl = card.querySelector('.hw2-suggestions');
        const msgEl = card.querySelector('.hw2-link-msg');

        btn.disabled = true;
        btn.innerHTML = '<i class="fas fa-spinner fa-spin mr-1"></i>Searching…';
        suggestionsEl.classList.add('hidden');
        msgEl.classList.add('hidden');

        try {
          const res = await fetch(`/api/tournaments/${tournamentId}/matches/${bMatchId}/suggest-hw2`);
          const data = await res.json();
          btn.disabled = false;
          btn.innerHTML = '<i class="fas fa-search mr-1" aria-hidden="true"></i>Find HW2 Match';

          if (!res.ok || data.suggestions.length === 0) {
            msgEl.textContent = data.error ?? 'No cached matches found between these players. Have both players look up their HW2 stats first.';
            msgEl.className = 'text-xs text-amber-400';
            msgEl.classList.remove('hidden');
            return;
          }

          suggestionsEl.classList.remove('hidden');
          suggestionsEl.innerHTML = '<p class="text-gray-500 text-xs mb-1">Recent matches found — click to use:</p>' +
            data.suggestions.map(s => {
              const outcomeLabel = s.inferred_winner
                ? `<span class="text-green-300 font-medium">${esc(s.inferred_winner)} wins</span>`
                : '<span class="text-gray-400 font-medium">Winner not in cache</span>';
              const dataWinner = s.inferred_winner ? esc(s.inferred_winner) : '';
              return `
              <div class="flex items-center gap-2 rounded border border-slate-700/40 bg-slate-900/40 px-3 py-2 text-xs">
                <div class="flex-1 min-w-0">
                  ${outcomeLabel}
                  <span class="text-gray-500 mx-1">·</span>
                  <span class="text-gray-400">${s.map_id ? esc(mapName(s.map_id)) : 'Unknown map'}</span>
                  <span class="text-gray-500 mx-1">·</span>
                  <span class="text-gray-500">${fmtDate(s.started_at)}</span>
                </div>
                <button
                  type="button"
                  class="use-suggestion-btn flex-none rounded border border-cyan-500/30 bg-cyan-500/10 px-2 py-1 text-cyan-300 hover:bg-cyan-500/20 transition-colors"
                  data-match-id="${esc(s.hw2_match_id)}"
                  data-map-id="${esc(s.map_id ?? '')}"
                  data-p1-leader="${s.p1_leader_id ?? ''}"
                  data-p2-leader="${s.p2_leader_id ?? ''}"
                  data-winner="${dataWinner}"
                >
                  Use this
                </button>
              </div>
            `;
            }).join('');

          // Wire "Use this" buttons
          suggestionsEl.querySelectorAll('.use-suggestion-btn').forEach(useBtn => {
            useBtn.addEventListener('click', () => {
              // Fill UUID field
              card.querySelector('.hw2-match-id').value = useBtn.dataset.matchId;
              // Set map
              if (useBtn.dataset.mapId) {
                for (const opt of card.querySelector('.match-map').options) {
                  if (opt.value === useBtn.dataset.mapId) { opt.selected = true; break; }
                }
              }
              // Set leaders
              if (useBtn.dataset.p1Leader) {
                for (const opt of card.querySelector('.match-p1-leader').options) {
                  if (opt.value === useBtn.dataset.p1Leader) { opt.selected = true; break; }
                }
              }
              if (useBtn.dataset.p2Leader) {
                for (const opt of card.querySelector('.match-p2-leader').options) {
                  if (opt.value === useBtn.dataset.p2Leader) { opt.selected = true; break; }
                }
              }
              const winnerName = useBtn.dataset.winner;
              msgEl.textContent = winnerName
                ? `Selected: ${winnerName} wins. Click their Wins button below to confirm.`
                : 'Match details filled — winner not determined from cache; pick the correct Wins button below.';
              msgEl.className = winnerName ? 'text-xs text-green-400' : 'text-xs text-cyan-400';
              msgEl.classList.remove('hidden');
              suggestionsEl.classList.add('hidden');
            });
          });
        } catch {
          btn.disabled = false;
          btn.innerHTML = '<i class="fas fa-search mr-1" aria-hidden="true"></i>Find HW2 Match';
          msgEl.textContent = 'Network error.';
          msgEl.className = 'text-xs text-red-400';
          msgEl.classList.remove('hidden');
        }
      });
    });

    // Wire manual lookup buttons
    list.querySelectorAll('.hw2-link-btn').forEach(btn => {
      btn.addEventListener('click', async () => {
        const card = btn.closest('[data-brackets-match-id]');
        const bMatchId = Number(card.dataset.bracketsMatchId);
        const hw2MatchId = card.querySelector('.hw2-match-id').value.trim();
        const msgEl = card.querySelector('.hw2-link-msg');

        if (!hw2MatchId) {
          msgEl.textContent = 'Paste a HW2 match UUID first.';
          msgEl.className = 'text-xs text-amber-400';
          msgEl.classList.remove('hidden');
          return;
        }
        btn.disabled = true;
        btn.textContent = 'Looking up…';
        try {
          const res = await fetch(`/api/tournaments/${tournamentId}/link-hw2`, {
            method: 'POST',
            headers: { 'content-type': 'application/json' },
            body: JSON.stringify({ hw2MatchId, bracketsMatchId: bMatchId }),
          });
          const data = await res.json();
          if (!res.ok) {
            msgEl.textContent = data.error ?? 'Lookup failed.';
            msgEl.className = 'text-xs text-red-400';
            msgEl.classList.remove('hidden');
            return;
          }
          if (data.map_id) {
            for (const opt of card.querySelector('.match-map').options) {
              if (opt.value === data.map_id) { opt.selected = true; break; }
            }
          }
          if (data.p1_leader_id) {
            for (const opt of card.querySelector('.match-p1-leader').options) {
              if (Number(opt.value) === data.p1_leader_id) { opt.selected = true; break; }
            }
          }
          if (data.p2_leader_id) {
            for (const opt of card.querySelector('.match-p2-leader').options) {
              if (Number(opt.value) === data.p2_leader_id) { opt.selected = true; break; }
            }
          }
          msgEl.textContent = `Found — winner: ${data.winner_gamertag}. Click their Wins button to confirm.`;
          msgEl.className = 'text-xs text-green-400';
          msgEl.classList.remove('hidden');
        } catch {
          msgEl.textContent = 'Network error.';
          msgEl.className = 'text-xs text-red-400';
          msgEl.classList.remove('hidden');
        } finally {
          btn.disabled = false;
          btn.textContent = 'Look Up';
        }
      });
    });

    // Wire declare winner & override buttons
    list.querySelectorAll('.declare-btn').forEach(btn => {
      btn.addEventListener('click', () => submitResult(btn, false, participants));
    });
    list.querySelectorAll('.override-btn').forEach(btn => {
      btn.addEventListener('click', () => submitResult(btn, true, participants));
    });
  }

  function renderCompletedMatches(tournament, matches) {
    const bd = tournament.bracket_data;
    if (!bd) return;

    const completedSection = document.getElementById('admin-completed-section');
    const completedList = document.getElementById('admin-completed-list');
    const completedCount = document.getElementById('completed-count');
    const bracketParticipants = bd.participant ?? [];
    const metaByBracketsId = new Map((matches ?? []).map(m => [m.brackets_match_id, m]));

    const completed = (bd.match ?? [])
      .filter(m => m.opponent1?.id != null && m.opponent2?.id != null && matchWinnerId(m) !== null)
      .sort((a, b) => (b.round_id - a.round_id) || (b.id - a.id));

    if (completed.length === 0) {
      completedSection.classList.add('hidden');
      completedList.innerHTML = '';
      completedCount.textContent = '';
      return;
    }

    completedSection.classList.remove('hidden');
    completedCount.textContent = `(${completed.length})`;
    completedList.innerHTML = completed.map(match => {
      const p1Name = participantNameById(bracketParticipants, match.opponent1.id);
      const p2Name = participantNameById(bracketParticipants, match.opponent2.id);
      const winnerName = participantNameById(bracketParticipants, matchWinnerId(match));
      const meta = metaByBracketsId.get(match.id);
      const mapLabel = meta?.map_id ? mapName(meta.map_id) : 'Map not recorded';

      return `
        <div class="rounded-lg border border-slate-700/40 bg-slate-800/20 p-4 space-y-3" data-completed-match-id="${match.id}">
          <div class="flex items-start justify-between gap-3 flex-wrap">
            <div class="space-y-1">
              <div class="text-sm font-semibold text-white">
                <span class="text-cyan-200">${esc(p1Name)}</span>
                <span class="text-gray-500 mx-2">vs</span>
                <span class="text-cyan-200">${esc(p2Name)}</span>
              </div>
              <p class="text-xs text-green-400">
                Winner: ${esc(winnerName)}
                <span class="text-gray-500 mx-1">·</span>
                ${esc(mapLabel)}
              </p>
            </div>
            <button
              type="button"
              class="reopen-match-btn inline-flex items-center gap-2 rounded-md border border-amber-500/40 bg-amber-500/10 px-3 py-2 text-xs font-semibold text-amber-300 hover:bg-amber-500/20 transition-colors"
              data-match-id="${match.id}"
            >
              <i class="fas fa-rotate-left" aria-hidden="true"></i>
              Reopen Match
            </button>
          </div>
          <p class="completed-match-msg hidden text-xs"></p>
        </div>
      `;
    }).join('');

    completedList.querySelectorAll('.reopen-match-btn').forEach(btn => {
      btn.addEventListener('click', async () => {
        const card = btn.closest('[data-completed-match-id]');
        const msgEl = card.querySelector('.completed-match-msg');
        const matchId = Number(btn.dataset.matchId);

        if (!confirm('Reopen this match and clear any later results that depended on it?')) return;

        btn.disabled = true;
        btn.innerHTML = '<i class="fas fa-spinner fa-spin" aria-hidden="true"></i> Reopening...';
        msgEl.classList.add('hidden');

        try {
          const res = await fetch(`/api/tournaments/${tournamentId}/matches/${matchId}/reset`, {
            method: 'POST',
            headers: { 'content-type': 'application/json' },
            body: JSON.stringify({ adminPassword }),
          });
          const data = await res.json();

          if (!res.ok) {
            msgEl.textContent = data.error ?? 'Failed to reopen match.';
            msgEl.className = 'completed-match-msg text-xs text-red-400';
            msgEl.classList.remove('hidden');
            btn.disabled = false;
            btn.innerHTML = '<i class="fas fa-rotate-left" aria-hidden="true"></i> Reopen Match';
            return;
          }

          msgEl.textContent = 'Match reopened. Downstream advancements were cleared.';
          msgEl.className = 'completed-match-msg text-xs text-green-400';
          msgEl.classList.remove('hidden');
          await refreshTournament();
        } catch {
          msgEl.textContent = 'Network error.';
          msgEl.className = 'completed-match-msg text-xs text-red-400';
          msgEl.classList.remove('hidden');
          btn.disabled = false;
          btn.innerHTML = '<i class="fas fa-rotate-left" aria-hidden="true"></i> Reopen Match';
        }
      });
    });
  }

  async function submitResult(btn, isOverride, participants) {
    const card = btn.closest('[data-brackets-match-id]');
    const bMatchId = Number(card.dataset.bracketsMatchId);
    const winnerName = btn.dataset.winner;
    const msgEl = card.querySelector('.match-msg');
    const mapId = card.querySelector('.match-map').value || null;
    const p1LeaderId = Number(card.querySelector('.match-p1-leader').value) || null;
    const p2LeaderId = Number(card.querySelector('.match-p2-leader').value) || null;
    const hw2MatchId = card.querySelector('.hw2-match-id').value.trim() || null;

    btn.disabled = true;
    msgEl.classList.add('hidden');

    try {
      let res, body;

      if (isOverride) {
        body = { adminPassword, winnerGamertag: winnerName, mapId, p1LeaderId, p2LeaderId };
        res = await fetch(`/api/tournaments/${tournamentId}/matches/${bMatchId}/override`, {
          method: 'POST',
          headers: { 'content-type': 'application/json' },
          body: JSON.stringify(body),
        });
      } else {
        const winner = participants.find(p => p.gamertag?.toLowerCase() === winnerName?.toLowerCase());
        if (!winner) {
          msgEl.textContent = 'Could not find participant record.';
          msgEl.className = 'text-xs text-red-400';
          msgEl.classList.remove('hidden');
          btn.disabled = false;
          return;
        }
        body = {
          adminPassword,
          winnerId: winner.id,
          mapId, p1LeaderId, p2LeaderId, hw2MatchId,
        };
        res = await fetch(`/api/tournaments/${tournamentId}/matches/${bMatchId}`, {
          method: 'PATCH',
          headers: { 'content-type': 'application/json' },
          body: JSON.stringify(body),
        });
      }

      const data = await res.json();
      if (!res.ok) {
        msgEl.textContent = data.error ?? 'Failed to record result.';
        msgEl.className = 'text-xs text-red-400';
        msgEl.classList.remove('hidden');
        btn.disabled = false;
        return;
      }

      // Update bracket in-place without page reload
      msgEl.textContent = data.tournament_status === 'completed'
        ? 'Tournament complete!'
        : 'Result recorded!';
      msgEl.className = 'text-xs text-green-400';
      msgEl.classList.remove('hidden');

      // Re-fetch and re-render
      await refreshTournament();
    } catch {
      msgEl.textContent = 'Network error.';
      msgEl.className = 'text-xs text-red-400';
      msgEl.classList.remove('hidden');
      btn.disabled = false;
    }
  }

  // ─── Refresh (in-place update) ────────────────────────────────────────────
  async function refreshTournament() {
    try {
      const res = await fetch(`/api/tournaments/${tournamentId}`);
      if (!res.ok) return;
      const data = await res.json();
      tournamentData = data;

      // Reset bracket & admin panel before re-render
      bracketWrapper.classList.add('hidden');
      bracketEmpty.classList.add('hidden');
      winnerBanner.classList.add('hidden');
      document.getElementById('admin-pending-section').classList.add('hidden');
      document.getElementById('admin-pending-list').innerHTML = '';
      document.getElementById('admin-completed-section').classList.add('hidden');
      document.getElementById('admin-completed-list').innerHTML = '';
      document.getElementById('ctrl-registration').classList.add('hidden');
      document.getElementById('ctrl-active').classList.add('hidden');
      document.getElementById('ctrl-completed').classList.add('hidden');

      renderPage(data);
      if (isAdmin) renderAdminPanel(data);
    } catch {
      // Silent fail — user can manually refresh
    }
  }

  // ─── Join button ──────────────────────────────────────────────────────────
  function wireJoinButton(tournament) {
    const joinBtn = document.getElementById('join-btn');
    const joinMsg = document.getElementById('join-msg');

    joinBtn.addEventListener('click', async () => {
      const gamertag = document.getElementById('join-gamertag').value.trim();
      const joinPassword = tournament.is_private
        ? document.getElementById('join-password').value.trim()
        : undefined;

      if (!gamertag) {
        joinMsg.textContent = 'Please enter your gamertag.';
        joinMsg.className = 'text-xs text-red-400';
        joinMsg.classList.remove('hidden');
        return;
      }

      joinBtn.disabled = true;
      joinMsg.classList.add('hidden');

      try {
        const res = await fetch(`/api/tournaments/${tournamentId}/join`, {
          method: 'POST',
          headers: { 'content-type': 'application/json' },
          body: JSON.stringify({ gamertag, ...(joinPassword ? { joinPassword } : {}) }),
        });
        const data = await res.json();

        if (!res.ok) {
          joinMsg.textContent = data.error ?? 'Failed to join.';
          joinMsg.className = 'text-xs text-red-400';
          joinMsg.classList.remove('hidden');
          joinBtn.disabled = false;
          return;
        }

        joinMsg.textContent = `${gamertag} joined!`;
        joinMsg.className = 'text-xs text-green-400';
        joinMsg.classList.remove('hidden');
        document.getElementById('join-gamertag').value = '';
        await refreshTournament();
      } catch {
        joinMsg.textContent = 'Network error. Please try again.';
        joinMsg.className = 'text-xs text-red-400';
        joinMsg.classList.remove('hidden');
        joinBtn.disabled = false;
      }
    });
  }

  // ─── Boot ──────────────────────────────────────────────────────────────────
  loadTournament();
</script>
