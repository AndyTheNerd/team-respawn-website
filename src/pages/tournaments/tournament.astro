            <span class="text-cyan-200">${esc(p1Name)}</span>
            <span class="text-gray-500 mx-2">vs</span>
            <span class="text-cyan-200">${esc(p2Name)}</span>
          </div>

          <!-- Metadata dropdowns -->
          <div class="grid grid-cols-3 gap-2 text-xs">
            <div>
              <label class="block text-gray-500 mb-1">Map</label>
              <select class="match-map w-full rounded border border-slate-600/40 bg-slate-900/60 px-2 py-1 text-gray-300 focus:outline-none">${mapOpts}</select>
            </div>
            <div>
              <label class="block text-gray-500 mb-1">${esc(p1Name)} Leader</label>
              <select class="match-p1-leader w-full rounded border border-slate-600/40 bg-slate-900/60 px-2 py-1 text-gray-300 focus:outline-none">${leaderOpts}</select>
            </div>
            <div>
              <label class="block text-gray-500 mb-1">${esc(p2Name)} Leader</label>
              <select class="match-p2-leader w-full rounded border border-slate-600/40 bg-slate-900/60 px-2 py-1 text-gray-300 focus:outline-none">${leaderOpts}</select>
            </div>
          </div>

          <!-- HW2 match auto-suggest -->
          <div class="space-y-2">
            <div class="flex items-center gap-2">
              <button type="button" class="suggest-btn text-xs rounded border border-slate-600/40 bg-slate-800/60 px-3 py-1 text-cyan-300 hover:bg-slate-700/60 transition-colors">
                <i class="fas fa-search mr-1" aria-hidden="true"></i>Find HW2 Match
              </button>
              <span class="text-gray-500 text-xs">or</span>
              <input
                type="text"
                class="hw2-match-id flex-1 rounded border border-slate-600/40 bg-slate-900/60 px-2 py-1 text-gray-300 text-xs placeholder-gray-600 focus:outline-none"
                placeholder="Paste HW2 match UUID"
              />
              <button type="button" class="hw2-link-btn text-xs rounded border border-cyan-500/30 bg-cyan-500/10 px-3 py-1 text-cyan-300 hover:bg-cyan-500/20 transition-colors">
