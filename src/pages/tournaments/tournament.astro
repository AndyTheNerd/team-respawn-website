  // ─── Bracket rendering ────────────────────────────────────────────────────
  function renderBracket(tournament, matches) {
    bracketEmpty.classList.add('hidden');
    bracketError.classList.add('hidden');
    renderTournamentWinner(tournament);

    const bv = window.bracketsViewer;
    if (!bv) {
      bracketError.textContent = 'Bracket viewer failed to load. Please refresh the page.';
      bracketError.classList.remove('hidden');
      return;
    }

    const bd = tournament.bracket_data;
    const matchMetaByBracketsId = new Map(
      (matches ?? []).map(m => [m.brackets_match_id, m])
    );

    bracketWrapper.classList.remove('hidden');

    bv.render(
      {
        stages: bd.stage ?? [],
        groups: bd.group ?? [],
        rounds: bd.round ?? [],
        matches: (bd.match ?? []).map(m => {
          const meta = matchMetaByBracketsId.get(m.id);
          return meta ? { ...m, _meta: meta } : m;
        }),
        matchGames: bd.match_game ?? [],
        participants: bd.participant ?? [],
      },
      {
        selector: '#bracket-container',
        clear: true,
        participantOriginPlacement: 'none',
        separatedChildCountLabel: false,
        showSlotsOrigin: false,
        showLowerBracketSlotsOrigin: false,
      }
    );

    decorateBracketMatches(tournament, matchMetaByBracketsId);
  }

  // ─── Pending matches ──────────────────────────────────────────────────────
  function renderPendingMatches(tournament, matches, participants) {
    const bd = tournament.bracket_data;
    if (!bd) return;

    const completedIds = new Set(
      matches.filter(m => m.status === 'completed').map(m => m.brackets_match_id)
    );
    const bracketParticipants = bd.participant ?? [];
    const getName = (bId) => bracketParticipants.find(p => p.id === bId)?.name ?? '—';

    const pending = (bd.match ?? []).filter(m =>
      m.opponent1?.id != null &&
      m.opponent2?.id != null &&
      m.opponent1?.result == null &&
      m.opponent2?.result == null &&
      !completedIds.has(m.id)
