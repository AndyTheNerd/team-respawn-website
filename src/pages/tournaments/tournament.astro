      leaders.map(l => `<option value="${l.id}">${esc(l.name)}</option>`).join('');
    const mapOpts = `<option value="">— optional —</option>` +
      tournamentPickerMaps.map(m => `<option value="${esc(m.id)}">${esc(m.name)}</option>`).join('');

    const list = document.getElementById('admin-pending-list');
    list.innerHTML = pending.map(m => {
      const p1Name = getName(m.opponent1.id);
