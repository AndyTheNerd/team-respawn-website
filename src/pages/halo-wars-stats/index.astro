  <SidePanel />

  <script src="/js/side-panel.js" is:inline></script>
  <script src="/js/tabs.js" is:inline></script>
  <script src="/js/dropdowns.js" is:inline></script>

  <script>
    import { state } from '../../lib/hw2/state';
    import { searchInput, searchBtn, staleBannerRetry, leadersToggle, leadersPanel, leadersChevron, insightsToggle, insightsPanel, insightsChevron, campaignToggle, campaignPanel, campaignChevron, shareModal, profileShareModal } from '../../lib/hw2/dom';
    import { startSearchPlaceholderRotation, stopSearchPlaceholderRotation } from '../../lib/hw2/placeholderRotation';
    import { setSearchCallback, renderRecentSearches } from '../../lib/hw2/localStorage';
    import { initShareModalListeners, closeShareModal } from '../../lib/hw2/shareCard';
    import { initProfileShareListeners, closeProfileShareModal } from '../../lib/hw2/profileShare';
    import { parseGamertagFromProfilePath } from '../../lib/hw2/urlProfile';
    import { performSearch } from '../../lib/hw2/search';
    import { runComparison } from '../../lib/hw2/comparePlayers';
    import { getMatchResult } from '../../utils/haloApi';

    function resolveGamertagFromMatch(matchPayload: any): string {
      const rawPlayers = matchPayload?.Players;
      const players = Array.isArray(rawPlayers)
        ? rawPlayers
        : (rawPlayers && typeof rawPlayers === 'object')
          ? Object.values(rawPlayers)
          : [];

      const getPlayerId = (player: any): string => {
        const value = player?.HumanPlayerId?.Gamertag
          || (typeof player?.HumanPlayerId === 'string' ? player.HumanPlayerId : '')
          || player?.Gamertag
          || player?.PlayerId;
        return String(value || '').trim();
      };

      const preferred = players.find((player: any) => {
        const id = getPlayerId(player);
        if (!id) return false;
        return !/^ai\s+\d+$/i.test(id);
      }) || players.find((player: any) => getPlayerId(player) !== '');

      return preferred ? getPlayerId(preferred) : '';
    }

    // --- Collapsible panels ---
    if (leadersToggle && leadersPanel) {
      const leadersLabel = leadersToggle.querySelector('.flex.items-center.gap-1 > span:first-child') as HTMLElement | null;
      const isExpanded = leadersToggle.getAttribute('aria-expanded') === 'true';
      if (leadersChevron) leadersChevron.style.transform = isExpanded ? 'rotate(180deg)' : 'rotate(0deg)';
      leadersToggle.addEventListener('click', () => {
        const expandedNow = leadersToggle.getAttribute('aria-expanded') === 'true';
        leadersToggle.setAttribute('aria-expanded', expandedNow ? 'false' : 'true');
        leadersPanel.classList.toggle('hidden', expandedNow);
        if (leadersChevron) leadersChevron.style.transform = expandedNow ? 'rotate(0deg)' : 'rotate(180deg)';
        if (leadersLabel) leadersLabel.textContent = expandedNow ? 'Expand' : 'Collapse';
      });
    }

    if (insightsToggle && insightsPanel) {
      const insightsLabel = insightsToggle.querySelector('.flex.items-center.gap-1 > span:first-child') as HTMLElement | null;
      const isExpanded = insightsToggle.getAttribute('aria-expanded') === 'true';
      if (insightsChevron) insightsChevron.style.transform = isExpanded ? 'rotate(180deg)' : 'rotate(0deg)';
      insightsToggle.addEventListener('click', () => {
        const expandedNow = insightsToggle.getAttribute('aria-expanded') === 'true';
        insightsToggle.setAttribute('aria-expanded', expandedNow ? 'false' : 'true');
        insightsPanel.classList.toggle('hidden', expandedNow);
        if (insightsChevron) insightsChevron.style.transform = expandedNow ? 'rotate(0deg)' : 'rotate(180deg)';
        if (insightsLabel) insightsLabel.textContent = expandedNow ? 'Expand' : 'Collapse';
      });
    }

    if (campaignToggle && campaignPanel) {
      const campaignLabel = campaignToggle.querySelector('.flex.items-center.gap-1 > span:first-child') as HTMLElement | null;
      const isExpanded = campaignToggle.getAttribute('aria-expanded') === 'true';
      if (campaignChevron) campaignChevron.style.transform = isExpanded ? 'rotate(180deg)' : 'rotate(0deg)';
      campaignToggle.addEventListener('click', () => {
        const expandedNow = campaignToggle.getAttribute('aria-expanded') === 'true';
        campaignToggle.setAttribute('aria-expanded', expandedNow ? 'false' : 'true');
        campaignPanel.classList.toggle('hidden', expandedNow);
        if (campaignChevron) campaignChevron.style.transform = expandedNow ? 'rotate(0deg)' : 'rotate(180deg)';
        if (campaignLabel) campaignLabel.textContent = expandedNow ? 'Expand' : 'Collapse';
      });
    }

    // --- Share modal listeners ---
    initShareModalListeners();
    initProfileShareListeners();

    document.addEventListener('keydown', (event) => {
      if (event.key !== 'Escape') return;
      if (shareModal && !shareModal.classList.contains('hidden')) {
        closeShareModal();
        return;
      }
      if (profileShareModal && !profileShareModal.classList.contains('hidden')) {
        closeProfileShareModal();
      }
    });

    staleBannerRetry?.addEventListener('click', () => {
      const target = state.currentGamertag || searchInput.value;
      if (target.trim()) {
        performSearch(target);
      }
    });

    // --- Compare Players wiring ---
    const compareToggle = document.getElementById('compare-toggle') as HTMLButtonElement | null;
    const comparePanel = document.getElementById('compare-panel') as HTMLElement | null;
    const compareChevron = compareToggle?.querySelector('.compare-chevron') as HTMLElement | null;
    const compareBtn = document.getElementById('compare-btn') as HTMLButtonElement | null;
    const compareGt1 = document.getElementById('compare-gt1') as HTMLInputElement | null;
    const compareGt2 = document.getElementById('compare-gt2') as HTMLInputElement | null;
    const compareResults = document.getElementById('compare-results') as HTMLElement | null;

    if (compareToggle && comparePanel) {
      compareToggle.addEventListener('click', () => {
        const isOpen = !comparePanel.classList.contains('hidden');
        comparePanel.classList.toggle('hidden', isOpen);
        if (compareChevron) compareChevron.style.transform = isOpen ? 'rotate(0deg)' : 'rotate(180deg)';
      });
    }

    const doCompare = () => {
      if (!compareGt1 || !compareGt2 || !compareResults) return;
      const gt1 = compareGt1.value.trim();
      const gt2 = compareGt2.value.trim();
      if (!gt1 || !gt2) return;
      runComparison(gt1, gt2, compareResults);
    };

    compareBtn?.addEventListener('click', doCompare);
    compareGt1?.addEventListener('keydown', (e) => { if (e.key === 'Enter') doCompare(); });
    compareGt2?.addEventListener('keydown', (e) => { if (e.key === 'Enter') doCompare(); });

    // --- Search wiring ---
    setSearchCallback((gt: string) => performSearch(gt));

    searchBtn.addEventListener('click', () => performSearch(searchInput.value));
    searchInput.addEventListener('keydown', (e) => {
      if (e.key === 'Enter') performSearch(searchInput.value);
    });
    searchInput.addEventListener('focus', () => stopSearchPlaceholderRotation(true));
    searchInput.addEventListener('blur', () => startSearchPlaceholderRotation());
    searchInput.addEventListener('input', () => {
      if (searchInput.value.trim() !== '') {
        stopSearchPlaceholderRotation(false);
      } else if (document.activeElement !== searchInput) {
        startSearchPlaceholderRotation();
      }
    });

    startSearchPlaceholderRotation();
    renderRecentSearches();

    // --- URL-based initialization ---
    const urlParams = new URLSearchParams(window.location.search);
    const pathGamertag = parseGamertagFromProfilePath(window.location.pathname);
    const queryGamertag = urlParams.get('gamertag')?.trim() || '';
    const initialGamertag = pathGamertag || queryGamertag;
    const matchIdParam = urlParams.get('matchId')?.trim() || '';
    if (matchIdParam) {
      state.pendingDeepLinkMatchId = matchIdParam;
    }
    if (initialGamertag) {
      stopSearchPlaceholderRotation(false);
      searchInput.value = initialGamertag;
      performSearch(initialGamertag, { matchId: matchIdParam || null });
    } else if (matchIdParam) {
      const matchResult = await getMatchResult(matchIdParam);
      const inferredGamertag = matchResult.ok ? resolveGamertagFromMatch(matchResult.data) : '';
      if (inferredGamertag) {
        stopSearchPlaceholderRotation(false);
        searchInput.value = inferredGamertag;
        performSearch(inferredGamertag, { matchId: matchIdParam });
      }
    }
  </script>
</BaseLayout>
