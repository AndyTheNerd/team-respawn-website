---
import { SITE_DESCRIPTION } from '../config.js';
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import SidePanel from '../components/SidePanel.astro';
import StorehausPromo from '../components/StorehausPromo.astro';
import AnnouncementBanner from '../components/AnnouncementBanner.astro';
import TwitchEmbed from '../components/TwitchEmbed.astro';
import HeroSection from '../components/HeroSection.astro';
import ChannelStats from '../components/ChannelStats.astro';
import YoutubeLatestVideos from '../components/YoutubeLatestVideos.astro';
import LatestBlogCarousel from '../components/LatestBlogCarousel.astro';
import RecentHW2Searches from '../components/RecentHW2Searches.astro';
---
<BaseLayout
  title="Team Respawn - RTS Gaming with some cringe"
  description={SITE_DESCRIPTION}
  keywords="Team Respawn, gaming walkthroughs, Halo Wars guides, Age of Empires guides, strategy games, video game guides, Halo FPS walkthroughs"
  canonical="https://www.teamrespawn.net/"
  ogTitle="Team Respawn - RTS Gaming with some cringe"
  ogDescription="Walkthroughs, HW2 stats lookup, videos, and blog guides for Halo Wars, Halo FPS, and Age of Empires."
  ogImage="https://www.teamrespawn.net/content/Team-Respawn-Full.png"
>
  <Fragment slot="head">
    <script is:inline>
      (function () {
        const legacyHomeHashes = {
          'halo-wars': '/halo-wars-guides',
          'age-of-empires': '/age-of-empires-guides',
          'age-of-mythology': '/age-of-mythology-guides',
          walkthroughs: '/blog?category=Walkthroughs',
          'other-projects': '/storehaus',
        };
        const hash = window.location.hash.replace(/^#/, '');
        if (legacyHomeHashes[hash]) {
          window.location.replace(legacyHomeHashes[hash]);
        }
      })();
    </script>
    <script type="application/ld+json">
      {
        "@context": "https://schema.org",
        "@type": "Organization",
        "name": "Team Respawn",
        "url": "https://www.teamrespawn.net",
        "logo": "https://www.teamrespawn.net/content/Team-Respawn-Full.png",
        "description": "Gaming channel dedicated to strategy lovers - especially fans of Halo Wars, Halo FPS, and Age of Empires.",
        "sameAs": [
          "https://www.youtube.com/@TeamRespawn",
          "https://www.twitch.tv/TeamRespawnTV",
          "https://discord.gg/TeamRespawn"
        ]
      }
    </script>
  </Fragment>

  <a
    href="#main-content"
    class="sr-only focus:not-sr-only focus:absolute focus:top-4 focus:left-4 focus:z-50 focus:bg-white focus:text-black focus:px-4 focus:py-2 focus:rounded"
  >
    Skip to main content
  </a>

  <div class="container mx-auto p-4 sm:p-8">
    <Header />

    <main id="main-content" class="space-y-8" aria-label="Home page content">
      <AnnouncementBanner
        message="Explore the HW2 Stats page to search any gamertag, check CSR, and review recent matches."
        href="/halo-wars-stats"
        linkText="Open HW2 Stats"
        storageKey="tr_hw2_announcement_dismissed_v1"
      />
      <HeroSection />
      <ChannelStats />
      <YoutubeLatestVideos />
      <LatestBlogCarousel />
      <TwitchEmbed channel="teamrespawntv" />
      <RecentHW2Searches showOpenStatsLink />
      <StorehausPromo />
    </main>

    <Footer />
  </div>

  <SidePanel />

  <script src="/js/side-panel.js" is:inline></script>
  <script src="/js/twitch-embed.js" is:inline></script>
  <script src="/js/dropdowns.js" is:inline></script>
</BaseLayout>
