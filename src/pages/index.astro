---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import SidePanel from '../components/SidePanel.astro';
import StorehausPromo from '../components/StorehausPromo.astro';
import AnnouncementBanner from '../components/AnnouncementBanner.astro';
import TwitchEmbed from '../components/TwitchEmbed.astro';
import HeroSection from '../components/HeroSection.astro';
import ChannelStats from '../components/ChannelStats.astro';
import YoutubeLatestVideos from '../components/YoutubeLatestVideos.astro';
import RecentHW2Searches from '../components/RecentHW2Searches.astro';
---
<BaseLayout
  title="Team Respawn - RTS Gaming with some cringe"
  description="Team Respawn is a thriving gaming channel led by Andy, dedicated to strategy lovers - especially fans of Halo Wars, Halo FPS, and Age of Empires. Watch full walkthroughs and in-depth strategy guides."
  keywords="Team Respawn, gaming walkthroughs, Halo Wars guides, Age of Empires guides, strategy games, video game guides, Halo FPS walkthroughs"
  canonical="https://www.teamrespawn.net/"
  ogTitle="Team Respawn - RTS Gaming with some cringe"
  ogDescription="Full walkthroughs and strategy guides for Halo Wars, Halo FPS, and Age of Empires."
  ogImage="https://www.teamrespawn.net/content/Team-Respawn-Full.png"
>
  <Fragment slot="head">
    <script type="application/ld+json">
      {
        "@context": "https://schema.org",
        "@type": "Organization",
        "name": "Team Respawn",
        "url": "https://www.teamrespawn.net",
        "logo": "https://www.teamrespawn.net/content/Team-Respawn-Full.png",
        "description": "Gaming channel dedicated to strategy lovers - especially fans of Halo Wars, Halo FPS, and Age of Empires.",
        "sameAs": [
          "https://www.youtube.com/@TeamRespawn",
          "https://www.twitch.tv/TeamRespawnTV",
          "https://discord.gg/TeamRespawn"
        ]
      }
    </script>
  </Fragment>

  <a
    href="#main-content"
    class="sr-only focus:not-sr-only focus:absolute focus:top-4 focus:left-4 focus:z-50 focus:bg-white focus:text-black focus:px-4 focus:py-2 focus:rounded"
  >
    Skip to main content
  </a>

  <div class="container mx-auto p-4 sm:p-8">
    <Header />

    <main id="main-content" role="main" aria-label="Home page content">

      <!-- Home tab panel -->
      <section id="home-content" role="tabpanel" aria-labelledby="home-tab" aria-label="Home content">
        <AnnouncementBanner
          message="Explore the HW2 Stats page to search any gamertag, check CSR, and review recent matches."
          href="/halo-wars-stats"
          linkText="Open HW2 Stats"
          storageKey="tr_hw2_announcement_dismissed_v1"
        />
        <HeroSection />
        <ChannelStats />
        <TwitchEmbed channel="teamrespawntv" />
      </section>

      <!-- Home-only featured content; hidden when switching tabs -->
      <div id="home-featured-content">

        <!-- Dynamic showcase -->
        <YoutubeLatestVideos />
        <RecentHW2Searches />
        <!-- Storehaus CTA -->
        <StorehausPromo class="mb-8" />

      </div>

      <!-- Walkthroughs tab panel -->
      <section
        id="walkthroughs-content"
        class="hidden flex flex-col gap-4"
        role="tabpanel"
        aria-labelledby="walkthroughs-tab"
        aria-label="Walkthroughs content"
      >
        <div class="flex flex-col sm:flex-row sm:items-center justify-between gap-3 bg-gray-800/60 border border-gray-700/60 rounded-xl px-4 py-3">
          <div class="flex flex-col">
            <span class="text-sm font-semibold text-gray-200">Sort walkthroughs</span>
            <span class="text-xs text-gray-400">Default: A -> Z</span>
          </div>
          <label class="flex items-center gap-2 text-sm text-gray-200" for="walkthroughs-sort-select">
            <span class="sr-only">Sort walkthroughs</span>
            <select
              id="walkthroughs-sort-select"
              class="bg-gray-900 border border-gray-700 rounded-lg px-3 py-2 text-sm text-gray-100 focus:outline-none focus:ring-2 focus:ring-purple-500"
              aria-label="Sort walkthroughs"
            >
              <option value="alpha">Alphabetical (A->Z)</option>
              <option value="reverse-alpha">Alphabetical (Z->A)</option>
              <option value="release-desc">Release date (newest)</option>
              <option value="release-asc">Release date (oldest)</option>
              <option value="series">Game series (A->Z)</option>
            </select>
          </label>
        </div>
        <div id="walkthroughs-grid" class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4 sm:gap-6 lg:gap-8" aria-live="polite"></div>
      </section>

      <!-- Halo Wars guides tab panel -->
      <section
        id="halo-wars-content"
        class="hidden grid grid-cols-1 gap-8"
        role="tabpanel"
        aria-labelledby="halo-wars-tab"
        aria-label="Halo Wars guides content"
      ></section>

      <!-- Age of Empires guides tab panel -->
      <section
        id="age-of-empires-content"
        class="hidden grid grid-cols-1 gap-8"
        role="tabpanel"
        aria-labelledby="age-of-empires-tab"
        aria-label="Age of Empires guides content"
      ></section>

      <!-- Age of Mythology guides tab panel -->
      <section
        id="age-of-mythology-content"
        class="hidden grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8"
        role="tabpanel"
        aria-labelledby="age-of-mythology-tab"
        aria-label="Age of Mythology guides content"
      ></section>

      <!-- Other projects tab panel -->
      <section
        id="other-projects-content"
        class="hidden"
        role="tabpanel"
        aria-labelledby="other-projects-tab"
        aria-label="Other projects content"
      >
        <div id="other-projects-grid" class="other-projects-masonry"></div>
      </section>

    </main>

    <Footer />
  </div>

  <SidePanel />

  <script src="/js/side-panel.js" is:inline></script>
  <script src="/js/tabs.js" is:inline></script>
  <script src="/js/dropdowns.js" is:inline></script>
  <script src="/js/video-card.js" is:inline></script>
  <script src="/js/project-card.js" is:inline></script>
  <script src="/js/home-content.js" is:inline></script>
  <script src="/js/main.js" is:inline></script>
</BaseLayout>
