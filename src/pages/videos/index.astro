---
import Footer from '../../components/Footer.astro';
import Header from '../../components/Header.astro';
import SidePanel from '../../components/SidePanel.astro';
import VideoDatabase from '../../components/videos/VideoDatabase.astro';
import { videos } from '../../data/videos';
import BaseLayout from '../../layouts/BaseLayout.astro';
import {
  buildVideoSearchRecords,
  filterAndSortVideos,
  getFormatOptions,
  getGameOptions,
  getSeriesOptions,
  getVideoLibraryStats,
  getYearOptions,
  paginateVideos,
  parseStateFromSearchParams,
} from '../../lib/videoUtils';
import blogPosts from '../../data/blogPosts.js';
import { buildVideoIdToBlogHrefMap } from '../../utils/videoBlogHrefMap';

const videoBlogHrefById = buildVideoIdToBlogHrefMap(blogPosts);
const searchableVideos = buildVideoSearchRecords(videos, videoBlogHrefById);
const initialState = parseStateFromSearchParams(Astro.url.searchParams, searchableVideos);
const filteredVideos = filterAndSortVideos(searchableVideos, initialState);
const pagination = paginateVideos(filteredVideos, initialState.page);
const hydratedState = {
  ...initialState,
  page: pagination.page,
};

const gameOptions = getGameOptions(searchableVideos);
const seriesOptions = getSeriesOptions(searchableVideos);
const formatOptions = getFormatOptions(searchableVideos);
const yearOptions = getYearOptions(searchableVideos);
const stats = getVideoLibraryStats(searchableVideos);
---

<BaseLayout
  title="Video Database - Team Respawn"
  description="Search the Team Respawn YouTube archive by game, series, year, and video format. Find Halo Wars 2, Age of Empires, and Age of Mythology content fast."
  keywords="Team Respawn video database, Halo Wars 2 videos, Age of Empires IV videos, Age of Mythology videos, Team Respawn archive"
  canonical="https://www.teamrespawn.net/videos/"
  ogTitle="Video Database - Team Respawn"
  ogDescription="Search the Team Respawn archive by game, series, release year, and video format."
  ogImage="https://www.teamrespawn.net/content/Team-Respawn-Full.png"
>
  <div class="container mx-auto p-4 sm:p-6 lg:p-8">
    <Header showPanelButton={true} />
    <SidePanel />

    <main id="main-content">
      <VideoDatabase
        videos={searchableVideos}
        initialState={hydratedState}
        pagination={pagination}
        totalMatches={filteredVideos.length}
        stats={stats}
        gameOptions={gameOptions}
        seriesOptions={seriesOptions}
        formatOptions={formatOptions}
        yearOptions={yearOptions}
      />
    </main>

    <div class="mt-12">
      <Footer />
    </div>
  </div>

  <script src="/js/side-panel.js" is:inline></script>
  <script src="/js/dropdowns.js" is:inline></script>
</BaseLayout>
