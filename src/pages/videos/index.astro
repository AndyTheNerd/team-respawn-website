---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import SidePanel from '../../components/SidePanel.astro';
import { videos } from '../../data/videos';
import {
  tagVideo,
  GAME_LABELS,
  SERIES_LABELS,
  FORMAT_LABELS,
  type GameTag,
  type SeriesTag,
  type FormatTag,
} from '../../lib/videoUtils';

// Tag all public videos at build time, newest first
const taggedVideos = videos
  .filter((v) => v.privacy === 'Public')
  .map(tagVideo)
  .sort((a, b) => b.publishedAt.localeCompare(a.publishedAt));

// Derive available years
const availableYears = [...new Set(taggedVideos.map((v) => v.year))]
  .filter((y) => y > 0)
  .sort((a, b) => b - a);

const videoJson = JSON.stringify(taggedVideos).replace(/</g, '\\u003c');

// Ordered lists for tile rendering
const gameOrder: { value: GameTag; label: string; icon: string; img?: string; title: string }[] = [
  { value: 'halo-wars-2',        label: 'HW2',         icon: 'fa-ring',               img: '/img/game-icons/halo-wars-2.png',        title: 'Halo Wars 2' },
  { value: 'halo-wars-1',        label: 'HW1',         icon: 'fa-circle-dot',         img: '/img/game-icons/halo-wars-1.png',        title: 'Halo Wars' },
  { value: 'aoe4',               label: 'AoE IV',      icon: 'fa-chess-rook',         img: '/img/game-icons/Age-of-Empires-IV.png',  title: 'Age of Empires IV' },
  { value: 'aoe2',               label: 'AoE II',      icon: 'fa-shield',             img: '/img/game-icons/Age-of-Empires-II.png',  title: 'Age of Empires II' },
  { value: 'aom',                label: 'AoM',         icon: 'fa-star',               img: '/img/game-icons/Retold.png',         title: 'Age of Mythology Retold' },
  { value: 'halo-fps',           label: 'Halo FPS',    icon: 'fa-crosshairs',         img: '/img/game-icons/H1-White.png',           title: 'Halo (FPS series)' },
  { value: 'gears',              label: 'Gears',       icon: 'fa-gears',              img: '/img/game-icons/Gears-Cog.png',          title: 'Gears of War' },
  { value: 'goblin-commander',   label: 'Goblin Commander', icon: 'fa-dragon',        img: '/img/game-icons/goblin-commander.png',   title: 'Goblin Commander' },
  { value: 'command-and-conquer',label: 'C&C',         icon: 'fa-bomb',               img: '/img/game-icons/command-and-conquer.png', title: 'Command & Conquer' },
  { value: 'company-of-heroes',  label: 'CoH',         icon: 'fa-explosion',          img: '/img/game-icons/Company-of-Heroes.png',  title: 'Company of Heroes' },
  { value: 'tempest-rising',     label: 'Tempest',     icon: 'fa-wind',                                                             title: 'Tempest Rising' },
  { value: 'spellforce',         label: 'Spellforce',  icon: 'fa-hat-wizard',         img: '/img/game-icons/spellforce.png',         title: 'Spellforce' },
  { value: 'ashes',              label: 'Ashes',       icon: 'fa-meteor',                                                            title: 'Ashes of the Singularity' },
  { value: 'other',              label: 'Other',       icon: 'fa-gamepad',                                                          title: 'Other games' },
];

const seriesOrder: { value: SeriesTag; label: string; icon: string; title: string }[] = [
  { value: 'mythbusters',  label: 'Mythbusters',   icon: 'fa-flask',           title: 'Mythbusters series' },
  { value: 'super-turtle', label: 'Super Turtle',  icon: 'fa-shield-halved',   title: 'Super Turtle series' },
  { value: 'walkthrough',  label: 'Walkthrough',   icon: 'fa-film',            title: 'Full walkthroughs' },
  { value: 'guide',        label: 'Guide',         icon: 'fa-lightbulb',       title: 'Strategy guides & how-tos' },
  { value: 'review',       label: 'Review',        icon: 'fa-star',            title: 'Reviews & first impressions' },
  { value: 'general',      label: 'General',       icon: 'fa-gamepad',         title: 'General gameplay' },
];

const formatOrder: { value: FormatTag; label: string; icon: string; title: string }[] = [
  { value: 'medium', label: '2-30 min', icon: 'fa-clock',         title: 'Medium-length videos' },
  { value: 'long',   label: '30 min+',  icon: 'fa-hourglass-half', title: 'Long-form videos and full playthroughs' },
];
---

<BaseLayout
  title="Video Database - Team Respawn"
  description="Search and filter all Team Respawn YouTube videos by game, series, format, and year. Find exactly the content you're looking for."
  keywords="Team Respawn videos, Halo Wars 2, Age of Empires 4, Mythbusters, Super Turtle, walkthroughs, shorts"
  canonical="https://www.teamrespawn.net/videos/"
  ogTitle="Video Database - Team Respawn"
  ogDescription="Search and filter all Team Respawn YouTube videos by game, series, format, and year."
  ogImage="https://www.teamrespawn.net/content/Team-Respawn-Full.png"
>
  <Fragment slot="head">
    <style>
      /* â”€â”€â”€ Composer Panel â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€ */
      .composer-panel {
        background: rgba(10, 14, 26, 0.85);
        backdrop-filter: blur(16px);
        border: 1px solid rgba(255,255,255,0.08);
        border-radius: 1rem;
        padding: 1.25rem;
        max-height: calc(100vh - 3rem);
        overflow-y: auto;
        overscroll-behavior: contain;
      }

      .composer-section-label {
        font-size: 0.6rem;
        font-weight: 700;
        letter-spacing: 0.12em;
        text-transform: uppercase;
        color: rgba(148, 163, 184, 0.6);
        margin-bottom: 0.5rem;
      }

      /* â”€â”€â”€ Composer Icon Tiles â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€ */
      .composer-grid {
        display: grid;
        gap: 0.35rem;
      }
      .composer-grid-games   { grid-template-columns: repeat(3, 1fr); }
      .composer-grid-series  { grid-template-columns: repeat(3, 1fr); }
      .composer-grid-format  { grid-template-columns: repeat(2, 1fr); }
      .composer-grid-years   { grid-template-columns: repeat(4, 1fr); }

      .composer-tile {
        position: relative;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        gap: 0.3rem;
        padding: 0.55rem 0.2rem 0.45rem;
        border-radius: 0.5rem;
        border: 1px solid rgba(255,255,255,0.07);
        background: rgba(30, 41, 59, 0.45);
        cursor: pointer;
        transition: all 0.15s ease;
        user-select: none;
        height: 62px;
        overflow: hidden;
      }

      .composer-tile:hover {
        border-color: rgba(168, 85, 247, 0.4);
        background: rgba(168, 85, 247, 0.08);
      }

      .composer-tile.active {
        border-color: rgba(168, 85, 247, 0.65);
        background: rgba(168, 85, 247, 0.16);
        box-shadow: 0 0 10px rgba(168, 85, 247, 0.18);
      }

      /* Fixed-size icon box so all tiles have identical icon area regardless of FA glyph width */
      .tile-icon-box {
        display: flex;
        align-items: center;
        justify-content: center;
        width: 1.5rem;
        height: 1.4rem;
        flex-shrink: 0;
      }
      .tile-icon-box i {
        font-size: 0.9rem;
        color: rgba(148, 163, 184, 0.65);
        transition: color 0.15s ease;
        line-height: 1;
      }
      .composer-tile.active .tile-icon-box i {
        color: rgba(196, 148, 255, 0.95);
      }
      .composer-tile:hover .tile-icon-box i {
        color: rgba(196, 148, 255, 0.8);
      }

      /* Game logo images inside tiles */
      .tile-img {
        width: 2.2rem;
        height: 1.4rem;
        object-fit: contain;
        display: block;
        opacity: 0.6;
        transition: opacity 0.15s ease, filter 0.15s ease;
        filter: grayscale(0.3);
      }
      .composer-tile:hover .tile-img {
        opacity: 0.9;
        filter: grayscale(0);
      }
      .composer-tile.active .tile-img {
        opacity: 1;
        filter: grayscale(0) drop-shadow(0 0 4px rgba(168, 85, 247, 0.35));
      }

      .composer-tile .tile-label {
        font-size: 0.52rem;
        font-weight: 600;
        letter-spacing: 0.03em;
        text-transform: uppercase;
        color: rgba(100, 116, 139, 0.9);
        text-align: center;
        line-height: 1.2;
        transition: color 0.15s ease;
      }
      .composer-tile.active .tile-label { color: rgba(216, 180, 254, 0.95); }
      .composer-tile:hover .tile-label  { color: rgba(203, 213, 225, 0.9); }

      /* MCC-style pip in bottom-left */
      .composer-tile::before {
        content: '';
        position: absolute;
        bottom: 4px;
        left: 4px;
        width: 5px;
        height: 5px;
        border-radius: 1px;
        border: 1px solid rgba(100, 116, 139, 0.35);
        background: transparent;
        transition: all 0.13s ease;
      }
      .composer-tile.active::before {
        background: rgba(168, 85, 247, 0.9);
        border-color: rgba(168, 85, 247, 0.9);
      }

      .shorts-toggle {
        width: 100%;
        margin-top: 0.45rem;
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 0.5rem;
        border-radius: 0.5rem;
        border: 1px solid rgba(255,255,255,0.08);
        background: rgba(30, 41, 59, 0.45);
        color: rgba(148, 163, 184, 0.9);
        font-size: 0.62rem;
        letter-spacing: 0.03em;
        font-weight: 600;
        padding: 0.5rem 0.6rem;
        transition: all 0.15s ease;
      }
      .shorts-toggle:hover {
        border-color: rgba(168,85,247,0.35);
        color: #cbd5e1;
      }
      .shorts-toggle.active {
        border-color: rgba(168,85,247,0.6);
        background: rgba(168,85,247,0.16);
        color: rgba(216,180,254,1);
      }
      .shorts-toggle-knob {
        width: 0.9rem;
        height: 0.9rem;
        border-radius: 9999px;
        background: rgba(100,116,139,0.8);
        box-shadow: inset 0 0 0 2px rgba(15,23,42,0.7);
        transition: background 0.15s ease;
        flex-shrink: 0;
      }
      .shorts-toggle.active .shorts-toggle-knob {
        background: rgba(168,85,247,0.95);
      }

      /* â”€â”€â”€ Sort pills â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€ */
      .sort-pill {
        padding: 0.22rem 0.55rem;
        border-radius: 9999px;
        border: 1px solid rgba(255,255,255,0.08);
        background: rgba(30, 41, 59, 0.5);
        font-size: 0.62rem;
        font-weight: 600;
        letter-spacing: 0.04em;
        text-transform: uppercase;
        color: rgba(100, 116, 139, 0.9);
        cursor: pointer;
        transition: all 0.13s ease;
        white-space: nowrap;
      }
      .sort-pill:hover { border-color: rgba(168,85,247,0.35); color: #cbd5e1; }
      .sort-pill.active {
        border-color: rgba(168,85,247,0.6);
        background: rgba(168,85,247,0.16);
        color: rgba(216,180,254,1);
      }

      /* â”€â”€â”€ Active filter chips â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€ */
      /* Chips sit inline in a flex row â€” no dramatic X button */
      .active-chip {
        display: inline-flex;
        align-items: center;
        gap: 0.4rem;
        padding: 0.15rem 0.38rem 0.15rem 0.58rem;
        border-radius: 9999px;
        background: rgba(51, 65, 85, 0.62);
        border: 1px solid rgba(34, 211, 238, 0.28);
        font-size: 0.7rem;
        font-weight: 600;
        letter-spacing: 0.03em;
        color: rgba(103, 232, 249, 0.95);
        transition: all 0.13s ease;
        white-space: nowrap;
      }
      .active-chip:hover {
        background: rgba(71, 85, 105, 0.68);
        border-color: rgba(34, 211, 238, 0.45);
      }
      .active-chip-remove {
        width: 1.15rem;
        height: 1.15rem;
        border: 0;
        border-radius: 9999px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        background: transparent;
        color: rgba(148, 163, 184, 0.9);
        transition: color 0.13s ease, background-color 0.13s ease;
        padding: 0;
      }
      .active-chip-remove:hover {
        color: rgba(248, 113, 113, 0.95);
        background: rgba(248, 113, 113, 0.12);
      }
      .active-chip-remove svg {
        width: 0.75rem;
        height: 0.75rem;
        stroke-width: 2;
      }

      /* â”€â”€â”€ Video Cards â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€ */
      .video-card {
        display: flex;
        flex-direction: column;
        background: rgba(15, 23, 42, 0.7);
        border: 1px solid rgba(255,255,255,0.06);
        border-radius: 0.75rem;
        overflow: hidden;
        transition: all 0.18s ease;
      }
      .video-card-link {
        text-decoration: none;
        color: inherit;
      }
      .video-card:hover,
      .video-card:focus-within {
        border-color: rgba(168, 85, 247, 0.3);
        transform: translateY(-2px);
        box-shadow: 0 8px 24px rgba(0,0,0,0.35);
      }
      .video-card-link:focus-visible {
        outline: 2px solid rgba(168,85,247,0.7);
        outline-offset: 2px;
      }

      .video-thumb-wrap {
        position: relative;
        aspect-ratio: 16/9;
        background: rgba(30,41,59,0.5);
        overflow: hidden;
      }
      .video-thumb-wrap img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        display: block;
      }
      .video-duration-overlay {
        position: absolute;
        bottom: 0.3rem;
        right: 0.35rem;
        background: rgba(0,0,0,0.78);
        color: #fff;
        font-size: 0.6rem;
        font-weight: 600;
        padding: 0.1rem 0.32rem;
        border-radius: 3px;
        letter-spacing: 0.02em;
        pointer-events: none;
      }

      .video-card-body {
        padding: 0.6rem 0.7rem 0.7rem;
        display: flex;
        flex-direction: column;
        gap: 0.45rem;
        flex: 1;
      }

      /* Title: prominent */
      .video-card-title {
        font-size: 0.8rem;
        font-weight: 600;
        color: #e2e8f0;
        line-height: 1.32;
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
        overflow: hidden;
      }

      /* Metadata box â€” series + date, visually distinct from the title */
      .video-card-meta {
        display: inline-flex;
        align-self: flex-start;
        align-items: center;
        gap: 0.4rem;
        padding: 0.22rem 0.5rem;
        background: rgba(2, 6, 23, 0.82);
        border: 1px solid rgba(148, 163, 184, 0.46);
        border-radius: 0.42rem;
        box-shadow: inset 0 0 0 1px rgba(15, 23, 42, 0.75);
        font-size: 0.62rem;
        line-height: 1.15;
        font-weight: 500;
        color: rgba(148,163,184,0.9);
      }
      .video-meta-series {
        display: inline-flex;
        align-items: center;
        gap: 0.25rem;
        color: rgba(196,148,255,0.85);
        flex-shrink: 0;
      }
      .video-meta-sep {
        opacity: 0.35;
        flex-shrink: 0;
      }
      .video-meta-date {
        display: inline-flex;
        align-items: center;
        gap: 0.25rem;
        flex-shrink: 0;
      }
      .video-card-meta i {
        font-size: 0.48rem;
        opacity: 0.6;
      }

      .video-card-actions {
        margin-top: auto;
        display: flex;
        align-items: center;
        justify-content: flex-end;
      }
      .video-share-btn {
        border: 1px solid rgba(148,163,184,0.25);
        background: rgba(30,41,59,0.55);
        color: rgba(148,163,184,0.95);
        border-radius: 0.45rem;
        padding: 0.22rem 0.5rem;
        font-size: 0.58rem;
        letter-spacing: 0.04em;
        text-transform: uppercase;
        font-weight: 700;
        display: inline-flex;
        align-items: center;
        gap: 0.3rem;
        transition: all 0.15s ease;
      }
      .video-share-btn:hover {
        border-color: rgba(168,85,247,0.55);
        color: rgba(216,180,254,0.95);
      }
      .video-share-btn.copied {
        border-color: rgba(34,197,94,0.75);
        color: rgba(134,239,172,1);
      }

      /* â”€â”€â”€ Empty state â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€ */
      .empty-state {
        grid-column: 1/-1;
        text-align: center;
        padding: 4rem 1rem;
        color: rgba(100,116,139,0.7);
      }

      /* â”€â”€â”€ Match counter â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€ */
      .match-counter {
        font-size: 0.68rem;
        font-weight: 700;
        letter-spacing: 0.06em;
        text-transform: uppercase;
        color: rgba(168,85,247,0.85);
      }

      .results-summary {
        font-size: 0.68rem;
        color: rgba(148,163,184,0.85);
        letter-spacing: 0.03em;
      }

      .vdb-pagination {
        margin-top: 1rem;
      }
      .vdb-pagination.hidden {
        display: none;
      }
      .vdb-pagination-controls {
        display: flex;
        flex-wrap: wrap;
        align-items: center;
        gap: 0.45rem;
      }
      .vdb-page-btn {
        border: 1px solid rgba(148,163,184,0.2);
        background: rgba(30,41,59,0.55);
        color: rgba(148,163,184,0.95);
        border-radius: 0.5rem;
        min-width: 2rem;
        padding: 0.32rem 0.6rem;
        font-size: 0.72rem;
        transition: all 0.15s ease;
      }
      .vdb-page-btn:hover {
        border-color: rgba(168,85,247,0.4);
        color: #e2e8f0;
      }
      .vdb-page-btn[aria-current='page'] {
        border-color: rgba(168,85,247,0.8);
        background: rgba(168,85,247,0.22);
        color: rgba(216,180,254,1);
      }
      .vdb-page-ellipsis {
        color: rgba(100,116,139,0.9);
        font-size: 0.8rem;
        padding: 0 0.2rem;
      }

      .vdb-scroll-top {
        position: fixed;
        right: 1rem;
        bottom: 1.25rem;
        width: 2.5rem;
        height: 2.5rem;
        border-radius: 9999px;
        border: 1px solid rgba(148,163,184,0.25);
        background: rgba(15,23,42,0.86);
        color: rgba(203,213,225,0.95);
        display: inline-flex;
        align-items: center;
        justify-content: center;
        opacity: 0;
        pointer-events: none;
        transform: translateY(8px);
        transition: opacity 0.2s ease, transform 0.2s ease, border-color 0.15s ease;
        z-index: 50;
      }
      .vdb-scroll-top.visible {
        opacity: 1;
        pointer-events: auto;
        transform: translateY(0);
      }
      .vdb-scroll-top:hover {
        border-color: rgba(168,85,247,0.55);
      }

      .vdb-visually-hidden {
        position: absolute;
        width: 1px;
        height: 1px;
        padding: 0;
        margin: -1px;
        overflow: hidden;
        clip: rect(0, 0, 0, 0);
        white-space: nowrap;
        border: 0;
      }

      /* â”€â”€â”€ Search input â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€ */
      .vdb-search-wrap {
        display: flex;
        align-items: center;
        gap: 0.5rem;
        background: rgba(30,41,59,0.6);
        border: 1px solid rgba(255,255,255,0.09);
        border-radius: 0.625rem;
        padding: 0.5rem 0.75rem;
        transition: border-color 0.18s;
      }
      .vdb-search-wrap:focus-within {
        border-color: rgba(168,85,247,0.45);
        box-shadow: 0 0 0 2px rgba(168,85,247,0.12);
      }
      .vdb-search-input {
        flex: 1;
        background: transparent;
        border: none;
        outline: none;
        color: #e2e8f0;
        font-size: 0.85rem;
        min-width: 0;
      }
      .vdb-search-input::placeholder { color: rgba(71, 85, 105, 0.8); }

