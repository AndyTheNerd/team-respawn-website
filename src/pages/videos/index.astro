  <!-- Data island -->
  <script type="application/json" id="vdb-data" set:html={videoJson}></script>

  <script define:vars={{ _unused: null }}>
    // Video database client logic
    const GAME_LABELS = {
      'halo-wars-2': 'Halo Wars 2', 'halo-wars-1': 'Halo Wars',
      aoe4: 'AoE IV', aoe2: 'AoE II',
      aom: 'Age of Mythology', 'halo-fps': 'Halo FPS',
      gears: 'Gears of War', 'goblin-commander': 'Goblin Commander',
      'command-and-conquer': 'C&C', 'company-of-heroes': 'CoH',
      'tempest-rising': 'Tempest Rising', spellforce: 'Spellforce',
      ashes: 'Ashes of the Singularity',
      other: 'Other',
    };
    const SERIES_LABELS = {
      mythbusters: 'Mythbusters', 'super-turtle': 'Super Turtle',
      walkthrough: 'Walkthrough', guide: 'Guide',
      review: 'Review', general: 'General',
    };
    const SERIES_ICONS = {
      mythbusters: 'fa-flask', 'super-turtle': 'fa-shield-halved',
      walkthrough: 'fa-film', guide: 'fa-lightbulb',
      review: 'fa-star', general: 'fa-gamepad',
    };
    const FORMAT_LABELS = {
      short: '<2 min',
      medium: '2-30 min',
      long: '30 min+',
    };

    const DEFAULT_FORMATS = new Set(['medium', 'long']);
    const DEFAULT_SORT = 'newest';
    const PAGE_SIZE = 50;
    const VALID_SORTS = new Set(['newest', 'oldest', 'longest', 'shortest', 'relevance']);
    const VALID_DURATION_FILTERS = new Set(['medium', 'long']);

    const state = {
      query: '',
      games: new Set(),
      series: new Set(),
      formats: new Set(DEFAULT_FORMATS),
      years: new Set(),
      includeShorts: false,
      sort: DEFAULT_SORT,
      page: 1,
    };

    let allVideos = [];
    try {
      allVideos = JSON.parse(document.getElementById('vdb-data').textContent || '[]');
      if (!Array.isArray(allVideos)) allVideos = [];
    } catch (e) {
      console.error('vdb: failed to parse video data', e);
      allVideos = [];
    }

    const grid               = document.getElementById('video-results-grid');
    const countEl            = document.getElementById('vdb-match-count');
    const chipsEl            = document.getElementById('vdb-active-chips');
    const searchInput        = document.getElementById('vdb-search-input');
    const searchClear        = document.getElementById('vdb-search-clear');
    const clearAllBtn        = document.getElementById('vdb-clear-all');
    const shortsToggle       = document.getElementById('vdb-shorts-toggle');
    const rangeSummaryEl     = document.getElementById('vdb-range-summary');
    const paginationNav      = document.getElementById('vdb-pagination');
    const paginationControls = document.getElementById('vdb-pagination-controls');
    const shareStatusEl      = document.getElementById('vdb-share-status');
    const scrollTopBtn       = document.getElementById('vdb-scroll-top');

    const VALID_GAMES = new Set(Object.keys(GAME_LABELS));
    const VALID_SERIES = new Set(Object.keys(SERIES_LABELS));
    const AVAILABLE_YEARS = new Set(
      allVideos.map(v => Number(v.year)).filter(y => Number.isInteger(y) && y > 0)
    );

    function esc(s) {
      return String(s || '')
        .replace(/&/g, '&amp;')
        .replace(/</g, '&lt;')
        .replace(/>/g, '&gt;')
        .replace(/"/g, '&quot;');
    }

    function fmtDuration(ms) {
      if (ms === null || ms === undefined || Number.isNaN(ms)) return '';
      const totalSec = Math.floor(ms / 1000);
      const h = Math.floor(totalSec / 3600);
      const m = Math.floor((totalSec % 3600) / 60);
      const s = totalSec % 60;
      if (h > 0) return m > 0 ? `${h}h ${m}m` : `${h}h`;
      if (m > 0) return s > 0 ? `${m}m ${s}s` : `${m}m`;
      return `${s}s`;
    }

    function fmtDate(iso) {
      if (!iso) return '';
      const d = new Date(iso);
      if (Number.isNaN(d.getTime())) return '';
      return d.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' });
    }

    function hasKnownDuration(video) {
      return typeof video.durationMs === 'number' && Number.isFinite(video.durationMs);
    }

    function compareDurationDesc(a, b) {
      const aKnown = hasKnownDuration(a);
      const bKnown = hasKnownDuration(b);
      if (aKnown && bKnown) return b.durationMs - a.durationMs;
      if (aKnown !== bKnown) return aKnown ? -1 : 1;
      return b.publishedAt.localeCompare(a.publishedAt);
    }

    function compareDurationAsc(a, b) {
      const aKnown = hasKnownDuration(a);
      const bKnown = hasKnownDuration(b);
      if (aKnown && bKnown) return a.durationMs - b.durationMs;
      if (aKnown !== bKnown) return aKnown ? -1 : 1;
      return b.publishedAt.localeCompare(a.publishedAt);
    }

    function getSearchableText(video) {
      const gameLabel = GAME_LABELS[video.game] || '';
      const seriesLabel = SERIES_LABELS[video.series] || '';
      return `${video.title || ''} ${gameLabel} ${seriesLabel}`.toLowerCase();
    }

    function scoreVideo(video, query) {
      if (!query) return 0;
      const q = query.toLowerCase().trim();
      if (!q) return 0;
      const title = String(video.title || '').toLowerCase();
      const searchable = getSearchableText(video);
      let score = 0;
      if (title === q) score += 200;
      if (title.startsWith(q)) score += 80;
      if (searchable.includes(q)) score += 40;
      q.split(/\s+/).forEach((word) => {
        if (word && searchable.includes(word)) score += 20;
      });
      return score;
    }

    function parseCsvParam(value, validSet, mapFn) {
      if (!value) return [];
      const raw = String(value).split(',').map(v => v.trim()).filter(Boolean);
      const parsed = mapFn ? raw.map(mapFn) : raw;
      return parsed.filter(v => validSet.has(v));
    }

    function setEquals(a, b) {
      if (a.size !== b.size) return false;
      for (const value of a) {
        if (!b.has(value)) return false;
      }
      return true;
    }

    function serializeSet(set) {
      return [...set].sort().join(',');
    }

    function hydrateStateFromUrl() {
      const params = new URLSearchParams(window.location.search);
      state.query = (params.get('q') || '').trim();
      state.games = new Set(parseCsvParam(params.get('games'), VALID_GAMES));
      state.series = new Set(parseCsvParam(params.get('series'), VALID_SERIES));
      state.years = new Set(parseCsvParam(params.get('years'), AVAILABLE_YEARS, value => Number(value)));
      state.includeShorts = params.get('shorts') === '1';

      if (params.has('dur')) {
        state.formats = new Set(parseCsvParam(params.get('dur'), VALID_DURATION_FILTERS));
      } else {
        state.formats = new Set(DEFAULT_FORMATS);
      }

      const sortParam = (params.get('sort') || '').toLowerCase();
      state.sort = VALID_SORTS.has(sortParam) ? sortParam : DEFAULT_SORT;

      const pageParam = Number(params.get('page'));
      state.page = Number.isInteger(pageParam) && pageParam > 0 ? pageParam : 1;
    }

    function syncStateToUrl() {
      const params = new URLSearchParams();
      if (state.query) params.set('q', state.query);
      if (state.games.size) params.set('games', serializeSet(state.games));
      if (state.series.size) params.set('series', serializeSet(state.series));
      if (state.years.size) params.set('years', serializeSet(state.years));
      if (!setEquals(state.formats, DEFAULT_FORMATS)) params.set('dur', serializeSet(state.formats));
      if (state.includeShorts) params.set('shorts', '1');
      if (state.sort !== DEFAULT_SORT) params.set('sort', state.sort);
      if (state.page > 1) params.set('page', String(state.page));

      const query = params.toString();
      const hash = window.location.hash || '';
      const nextUrl = query ? `${window.location.pathname}?${query}${hash}` : `${window.location.pathname}${hash}`;
      const currentUrl = `${window.location.pathname}${window.location.search}${hash}`;
      if (nextUrl !== currentUrl) {
        window.history.replaceState(null, '', nextUrl);
      }
    }

    function applyStateToUi() {
      searchInput.value = state.query;
      searchClear.classList.toggle('hidden', !state.query);

      document.querySelectorAll('.composer-tile[data-filter-type]').forEach((btn) => {
        const type = btn.dataset.filterType;
        const value = btn.dataset.filterValue;
        let isActive = false;
        if (type === 'game') isActive = state.games.has(value);
        if (type === 'series') isActive = state.series.has(value);
        if (type === 'year') isActive = state.years.has(parseInt(value, 10));
        if (type === 'format') isActive = state.formats.has(value);
        btn.classList.toggle('active', isActive);
        btn.setAttribute('aria-pressed', String(isActive));
      });

      if (shortsToggle) {
        shortsToggle.classList.toggle('active', state.includeShorts);
        shortsToggle.setAttribute('aria-pressed', String(state.includeShorts));
      }

      document.querySelectorAll('.sort-pill').forEach((pill) => {
        pill.classList.toggle('active', pill.dataset.sort === state.sort);
      });
    }

    function getFilteredAndSorted() {
      let results = allVideos.slice();

      if (state.games.size) results = results.filter(v => state.games.has(v.game));
      if (state.series.size) results = results.filter(v => state.series.has(v.series));
      if (state.years.size) results = results.filter(v => state.years.has(v.year));

      const allowedFormats = new Set(state.formats);
      if (state.includeShorts) allowedFormats.add('short');
      if (allowedFormats.size) results = results.filter(v => allowedFormats.has(v.format));
      else results = [];

      if (state.query) {
        const q = state.query.toLowerCase();
        results = results.filter(v => getSearchableText(v).includes(q));
      }

      if (state.sort === 'newest') results.sort((a, b) => b.publishedAt.localeCompare(a.publishedAt));
      else if (state.sort === 'oldest') results.sort((a, b) => a.publishedAt.localeCompare(b.publishedAt));
      else if (state.sort === 'longest') results.sort(compareDurationDesc);
      else if (state.sort === 'shortest') results.sort(compareDurationAsc);
      else if (state.sort === 'relevance') {
        if (state.query) results.sort((a, b) => scoreVideo(b, state.query) - scoreVideo(a, state.query));
        else results.sort((a, b) => b.publishedAt.localeCompare(a.publishedAt));
      }

      return results;
    }

    function getPaginationWindow(totalPages, currentPage) {
      if (totalPages <= 7) {
        return Array.from({ length: totalPages }, (_, i) => i + 1);
      }
      const pages = new Set([1, totalPages, currentPage]);
      if (currentPage - 1 > 1) pages.add(currentPage - 1);
      if (currentPage + 1 < totalPages) pages.add(currentPage + 1);
      if (currentPage <= 3) pages.add(2);
      if (currentPage >= totalPages - 2) pages.add(totalPages - 1);
      return [...pages].sort((a, b) => a - b);
    }

    function renderPagination(totalPages) {
      if (!paginationNav || !paginationControls) return;
      paginationControls.innerHTML = '';
      if (totalPages <= 1) {
        paginationNav.classList.add('hidden');
        return;
      }

      paginationNav.classList.remove('hidden');

      const addButton = (label, page, disabled, ariaCurrent = false) => {
        const button = document.createElement('button');
        button.type = 'button';
        button.className = 'vdb-page-btn';
        button.textContent = label;
        button.dataset.page = String(page);
        if (disabled) button.disabled = true;
        if (ariaCurrent) button.setAttribute('aria-current', 'page');
        paginationControls.appendChild(button);
      };

      addButton('Previous', Math.max(1, state.page - 1), state.page === 1);

      const pages = getPaginationWindow(totalPages, state.page);
      let prevPage = 0;
      pages.forEach((page) => {
        if (prevPage && page - prevPage > 1) {
          const ellipsis = document.createElement('span');
          ellipsis.className = 'vdb-page-ellipsis';
          ellipsis.textContent = '...';
          paginationControls.appendChild(ellipsis);
        }
        addButton(String(page), page, false, page === state.page);
        prevPage = page;
      });

      addButton('Next', Math.min(totalPages, state.page + 1), state.page === totalPages);
    }

    function renderChips() {
      const chips = [];
      state.games.forEach(v => chips.push({ label: GAME_LABELS[v] || v, type: 'game', value: v }));
      state.series.forEach(v => chips.push({ label: SERIES_LABELS[v] || v, type: 'series', value: v }));
      state.formats.forEach(v => chips.push({ label: FORMAT_LABELS[v] || v, type: 'format', value: v }));
      if (state.includeShorts) chips.push({ label: 'Shorts included', type: 'shorts', value: '1' });
      state.years.forEach(v => chips.push({ label: String(v), type: 'year', value: v }));

      if (!chips.length) {
        chipsEl.innerHTML = '';
        return;
      }

      chipsEl.innerHTML = chips.map(chip => `
        <div
          class="active-chip"
          data-chip-type="${esc(chip.type)}"
          data-chip-value="${esc(String(chip.value))}"
        >
          <span class="active-chip-label">${esc(chip.label)}</span>
          <button type="button" class="active-chip-remove" aria-label="Remove filter: ${esc(chip.label)}">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <line x1="18" y1="6" x2="6" y2="18"></line>
              <line x1="6" y1="6" x2="18" y2="18"></line>
            </svg>
          </button>
        </div>
      `).join('');
    }

    function renderResults() {
      const results = getFilteredAndSorted();
      const total = results.length;
      countEl.textContent = `${total.toLocaleString()} video${total === 1 ? '' : 's'} match`;
      grid.setAttribute('aria-busy', 'false');

      const totalPages = Math.max(1, Math.ceil(total / PAGE_SIZE));
      if (state.page > totalPages) state.page = totalPages;

      if (total === 0) {
        rangeSummaryEl.textContent = 'Showing 0 of 0';
        const hasFilters = state.games.size || state.series.size || state.formats.size !== DEFAULT_FORMATS.size || state.includeShorts || state.years.size || state.query.trim();
        grid.innerHTML = `
          <div class="empty-state">
            <i class="fas fa-magnifying-glass text-4xl mb-3 opacity-20 block"></i>
            <p class="text-base font-semibold text-slate-400 mb-1">No videos match</p>
            ${hasFilters ? '<p class="text-sm text-slate-600">Try removing a filter or broadening your search.</p>' : ''}
          </div>`;
        renderPagination(0);
        return;
      }

      const startIndex = (state.page - 1) * PAGE_SIZE;
      const endIndex = Math.min(startIndex + PAGE_SIZE, total);
      rangeSummaryEl.textContent = `Showing ${startIndex + 1}-${endIndex} of ${total.toLocaleString()}`;

      const pageResults = results.slice(startIndex, endIndex);
      const fragment = document.createDocumentFragment();

      pageResults.forEach((video) => {
        const thumb = `https://i.ytimg.com/vi/${video.videoId}/mqdefault.jpg`;
        const dur = fmtDuration(video.durationMs);
        const date = fmtDate(video.publishedAt);
        const gameLabel = GAME_LABELS[video.game] || video.game;
        const seriesLabel = SERIES_LABELS[video.series] || video.series;
        const seriesIcon = SERIES_ICONS[video.series] || 'fa-gamepad';
        const videoUrl = `https://www.youtube.com/watch?v=${video.videoId}`;
        const seriesMeta = video.series !== 'general'
          ? `<span class="video-meta-series"><i class="fas ${esc(seriesIcon)}" aria-hidden="true"></i>${esc(seriesLabel)}</span><span class="video-meta-sep">•</span>`
          : '';

        const card = document.createElement('article');
        card.className = 'video-card';
        card.setAttribute('role', 'listitem');
        card.innerHTML = `
          <a href="${esc(videoUrl)}" target="_blank" rel="noopener noreferrer" class="video-card-link" aria-label="${esc(video.title)} - ${esc(gameLabel)}, ${esc(date)}">
            <div class="video-thumb-wrap">
              <img src="${esc(thumb)}" alt="" loading="lazy" width="320" height="180" />
              ${dur ? `<div class="video-duration-overlay">${esc(dur)}</div>` : ''}
            </div>
          </a>
          <div class="video-card-body">
            <a href="${esc(videoUrl)}" target="_blank" rel="noopener noreferrer" class="video-card-link">
              <div class="video-card-title">${esc(video.title)}</div>
            </a>
            <div class="video-card-meta">
              ${seriesMeta}
              <span class="video-meta-date"><i class="fas fa-calendar-days" aria-hidden="true"></i>${esc(date)}</span>
            </div>
            <div class="video-card-actions">
              <button type="button" class="video-share-btn" data-video-url="${esc(videoUrl)}" aria-label="Copy YouTube link">
                <i class="fas fa-link" aria-hidden="true"></i>
                <span class="video-share-label">Copy Link</span>
              </button>
            </div>
          </div>
        `;
        fragment.appendChild(card);
      });

      grid.innerHTML = '';
      grid.appendChild(fragment);
      renderPagination(totalPages);
    }

    function renderAll({ syncUrl = true } = {}) {
      applyStateToUi();
      renderChips();
      renderResults();
      if (syncUrl) syncStateToUrl();
    }

    function toggleTile(button) {
      const type = button.dataset.filterType;
      const value = button.dataset.filterValue;
      const setMap = { game: state.games, series: state.series, format: state.formats, year: state.years };
      const setRef = setMap[type];
      if (!setRef) return;
      const parsedValue = type === 'year' ? parseInt(value, 10) : value;
      if (setRef.has(parsedValue)) setRef.delete(parsedValue);
      else setRef.add(parsedValue);
      state.page = 1;
      renderAll();
    }

    function resetToDefaults() {
      state.query = '';
      state.games.clear();
      state.series.clear();
      state.formats = new Set(DEFAULT_FORMATS);
      state.years.clear();
      state.includeShorts = false;
      state.sort = DEFAULT_SORT;
      state.page = 1;
      renderAll();
    }

    async function copyVideoUrl(url, button) {
      let copied = false;
      if (navigator.clipboard && navigator.clipboard.writeText) {
        try {
          await navigator.clipboard.writeText(url);
          copied = true;
        } catch (err) {
          copied = false;
        }
      }

      if (!copied) {
        window.prompt('Copy this YouTube link:', url);
        if (shareStatusEl) shareStatusEl.textContent = 'Copy link prompt opened.';
        return;
      }

      if (shareStatusEl) shareStatusEl.textContent = 'YouTube link copied to clipboard.';
      button.classList.add('copied');
      const label = button.querySelector('.video-share-label');
      if (label) label.textContent = 'Copied';
      window.setTimeout(() => {
        button.classList.remove('copied');
        if (label) label.textContent = 'Copy Link';
      }, 1800);
    }

    function updateScrollTopVisibility() {
      if (!scrollTopBtn) return;
      scrollTopBtn.classList.toggle('visible', window.scrollY > 400);
    }

    chipsEl.addEventListener('click', (event) => {
      const removeBtn = event.target.closest('.active-chip-remove');
      if (!removeBtn) return;
      const chip = event.target.closest('.active-chip');
      if (!chip) return;
      const type = chip.dataset.chipType;
      const value = chip.dataset.chipValue;

      if (type === 'shorts') {
        state.includeShorts = false;
        state.page = 1;
        renderAll();
        return;
      }

      const setMap = { game: state.games, series: state.series, format: state.formats, year: state.years };
      const setRef = setMap[type];
      if (!setRef) return;
      const parsedValue = type === 'year' ? parseInt(value, 10) : value;
      setRef.delete(parsedValue);
      state.page = 1;
      renderAll();
    });

    document.querySelectorAll('.composer-tile[data-filter-type]').forEach((button) => {
      button.addEventListener('click', () => toggleTile(button));
    });

    if (shortsToggle) {
      shortsToggle.addEventListener('click', () => {
        state.includeShorts = !state.includeShorts;
        state.page = 1;
        renderAll();
      });
    }

    document.querySelectorAll('.sort-pill').forEach((pill) => {
      pill.addEventListener('click', () => {
        const nextSort = pill.dataset.sort;
        if (!VALID_SORTS.has(nextSort)) return;
        state.sort = nextSort;
        state.page = 1;
        renderAll();
      });
    });

    let searchTimer;
    searchInput.addEventListener('input', () => {
      window.clearTimeout(searchTimer);
      searchTimer = window.setTimeout(() => {
        state.query = searchInput.value.trim();
        if (state.query && state.sort === DEFAULT_SORT) state.sort = 'relevance';
        if (!state.query && state.sort === 'relevance') state.sort = DEFAULT_SORT;
        state.page = 1;
        renderAll();
      }, 180);
    });

    searchClear.addEventListener('click', () => {
      searchInput.value = '';
      state.query = '';
      if (state.sort === 'relevance') state.sort = DEFAULT_SORT;
      state.page = 1;
      renderAll();
    });

    clearAllBtn.addEventListener('click', () => {
      resetToDefaults();
    });

    if (paginationControls) {
      paginationControls.addEventListener('click', (event) => {
        const button = event.target.closest('.vdb-page-btn[data-page]');
        if (!button || button.disabled) return;
        const page = parseInt(button.dataset.page, 10);
        if (!Number.isInteger(page) || page < 1 || page === state.page) return;
        state.page = page;
        renderAll();
        grid.scrollIntoView({ behavior: 'smooth', block: 'start' });
      });
    }

    if (grid) {
      grid.addEventListener('click', (event) => {
        const button = event.target.closest('.video-share-btn');
        if (!button) return;
        const url = button.dataset.videoUrl;
        if (!url) return;
        copyVideoUrl(url, button);
      });
    }

    if (scrollTopBtn) {
      scrollTopBtn.addEventListener('click', () => {
        window.scrollTo({ top: 0, behavior: 'smooth' });
      });
      window.addEventListener('scroll', updateScrollTopVisibility, { passive: true });
      updateScrollTopVisibility();
    }

    const composerToggle = document.getElementById('vdb-composer-toggle');
    const composerBody = document.getElementById('vdb-composer-body');
    const composerChevron = document.getElementById('vdb-composer-chevron');
    if (composerToggle && composerBody) {
      composerToggle.addEventListener('click', () => {
        const open = composerBody.classList.toggle('open');
        composerToggle.setAttribute('aria-expanded', String(open));
        if (composerChevron) composerChevron.style.transform = open ? 'rotate(180deg)' : '';
      });
    }

    hydrateStateFromUrl();
    renderAll({ syncUrl: false });

    window.addEventListener('popstate', () => {
      hydrateStateFromUrl();
      renderAll({ syncUrl: false });
    });
  </script>

  <!-- Side panel + header functionality -->
  <script src="/js/side-panel.js" is:inline></script>
  <script src="/js/tabs.js" is:inline></script>
  <script src="/js/dropdowns.js" is:inline></script>
</BaseLayout>

