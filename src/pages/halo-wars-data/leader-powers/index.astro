---
import HW2HubNav from '../../../components/HW2HubNav.astro';
import HW2ReferenceDirectory from '../../../components/HW2ReferenceDirectory.astro';
import SecondaryPageLayout from '../../../layouts/SecondaryPageLayout.astro';
---

<SecondaryPageLayout
  title="Halo Wars 2 Leader Powers - Team Respawn"
  description="Browse Halo Wars 2 leader powers from Team Respawn’s cached metadata endpoint."
  keywords="Halo Wars 2 leader powers, HW2 powers, Team Respawn data"
  canonical="https://www.teamrespawn.net/halo-wars-data/leader-powers/"
  ogTitle="Halo Wars 2 Leader Powers - Team Respawn"
  ogDescription="Searchable Halo Wars 2 leader power metadata cached through Team Respawn."
>
  <main id="main-content">
    <section class="mb-8 rounded-xl border border-cyan-500/20 bg-gradient-to-br from-slate-950 via-slate-900 to-emerald-950/30 px-6 py-10">
      <p class="text-sm uppercase tracking-[0.2em] text-cyan-300">Halo Wars 2 Data</p>
      <h1 class="mt-3 text-3xl font-bold text-slate-100 sm:text-4xl">Leader Powers</h1>
      <p class="mt-4 max-w-3xl text-base text-slate-300">
        Live metadata view backed by the existing Team Respawn leader power cache endpoint. Use it to cross-check names seen in event timelines and match summaries.
      </p>
    </section>

    <HW2HubNav current="data" currentDataSection="leader-powers" />

    <HW2ReferenceDirectory
      rootId="hw2-leader-powers-directory"
      title="Leader Power Directory"
      subtitle="Metadata-backed leader power names loaded from the existing cached Pages Function."
      dataSources={[{ url: '/api/hw2/leader-powers', label: 'Leader Powers' }]}
      filterPlaceholder="Search powers by name or object ID"
    />
  </main>
</SecondaryPageLayout>
