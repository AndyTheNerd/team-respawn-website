---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import SidePanel from '../../components/SidePanel.astro';
---
<BaseLayout
  title="Support Us | Team Respawn"
  description="Support Team Respawn and help us keep creating RTS guides, tools, and community content."
  keywords="Team Respawn, support, donate, RTS gaming, Halo Wars 2"
  canonical="https://www.teamrespawn.net/support"
  ogTitle="Support Us | Team Respawn"
  ogDescription="Support Team Respawn and help us keep creating RTS guides, tools, and community content."
  ogImage="https://www.teamrespawn.net/content/Banner.jpg"
>
  <a
    href="#main-content"
    class="sr-only focus:not-sr-only focus:absolute focus:top-4 focus:left-4 focus:z-50 focus:bg-white focus:text-black focus:px-4 focus:py-2 focus:rounded"
  >
    Skip to main content
  </a>

  <div class="container mx-auto p-4 sm:p-8">
    <Header />

    <main id="main-content" class="max-w-4xl mx-auto mt-8" role="main" aria-label="Support Team Respawn">
      <article class="bg-gray-800/60 border border-gray-700/60 rounded-xl p-6 sm:p-8 lg:p-10">
        <header class="mb-8">
          <h1 class="text-4xl sm:text-5xl lg:text-6xl font-extrabold mb-4 text-transparent bg-clip-text bg-gradient-to-r from-purple-400 to-pink-400">
            Support Us
          </h1>
          <p class="text-gray-400 text-lg">
            Everything we create — guides, tools, videos, and bots — is free. Your support keeps it that way.
          </p>
        </header>

        <div class="prose prose-invert prose-lg max-w-none">
          <section class="mb-8">
            <h2 class="text-2xl sm:text-3xl font-bold mb-4 text-purple-300">Ways to Support</h2>
            <p class="text-gray-300 leading-relaxed mb-6">
              We don't have a paywall or premium tier. The best way to support Team Respawn is to engage with our content and share it with others who might find it useful.
            </p>
            <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
              <div class="bg-gray-800/60 p-4 rounded-lg border border-gray-700/60 hover:border-purple-500/40 transition-colors duration-300">
                <i class="fab fa-youtube text-red-400 text-2xl mb-2" aria-hidden="true"></i>
                <h3 class="font-semibold text-purple-200 mb-1">Subscribe on YouTube</h3>
                <p class="text-sm text-gray-400">Watch and subscribe to our channel for the latest RTS guides and content</p>
              </div>
              <div class="bg-gray-800/60 p-4 rounded-lg border border-gray-700/60 hover:border-purple-500/40 transition-colors duration-300">
                <i class="fab fa-twitch text-purple-400 text-2xl mb-2" aria-hidden="true"></i>
                <h3 class="font-semibold text-purple-200 mb-1">Follow on Twitch</h3>
                <p class="text-sm text-gray-400">Catch live streams and join the conversation in real time</p>
              </div>
              <div class="bg-gray-800/60 p-4 rounded-lg border border-gray-700/60 hover:border-purple-500/40 transition-colors duration-300">
                <i class="fas fa-share-alt text-purple-400 text-2xl mb-2" aria-hidden="true"></i>
                <h3 class="font-semibold text-purple-200 mb-1">Share Our Content</h3>
                <p class="text-sm text-gray-400">Share guides and videos with your community — it makes a huge difference</p>
              </div>
            </div>
          </section>

          <section class="mb-8">
            <h2 class="text-2xl sm:text-3xl font-bold mb-4 text-purple-300">Coming Soon</h2>
            <p class="text-gray-300 leading-relaxed mb-4">
              We're exploring additional ways for supporters to contribute directly. More details to come.
            </p>
            <ul class="list-disc list-inside mb-4 space-y-2 text-gray-300 ml-4">
              <li>Patreon membership — <span class="text-gray-500">coming soon</span></li>
              <li>YouTube channel membership — <span class="text-gray-500">coming soon</span></li>
            </ul>
          </section>
        </div>
      </article>
    </main>

    <Footer />
  </div>

  <SidePanel />

  <script src="/js/side-panel.js" is:inline></script>
  <script src="/js/tabs.js" is:inline></script>
  <script src="/js/dropdowns.js" is:inline></script>
  <script src="/js/secondary-init.js" is:inline></script>
</BaseLayout>
