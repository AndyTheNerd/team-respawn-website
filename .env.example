# Cloudinary Configuration
# Get these values from your Cloudinary dashboard
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# Halo Wars 2 API Keys (Ocp-Apim-Subscription-Key)
PUBLIC_HW2_API_KEY_1=your-primary-halo-api-key
PUBLIC_HW2_API_KEY_2=your-secondary-halo-api-key
PUBLIC_HW2_API_KEY_3=your-tertiary-halo-api-key

# Cloudflare Analytics
# Create a token at dash.cloudflare.com/profile/api-tokens
# Required permission: Zone → Zone Analytics → Read (scoped to your domain)
# Zone ID is found on the Overview page for your domain in the Cloudflare dashboard
CLOUDFLARE_API_TOKEN=your-cloudflare-api-token
CLOUDFLARE_ZONE_ID=your-cloudflare-zone-id

# Pages Functions (wrangler dev / .dev.vars) — optional long random string for HW2 tournament admin
# password rate limiting. D1 stores only SHA-256(pepper|tournamentId|ip), not raw IPs. Omit to disable limits locally.
# TOURNAMENT_RATE_LIMIT_PEPPER=